---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    noindex?: boolean;
}

const {
    title = 'GalexC',
    description = 'GalexC builds durable agentic systems for real work.',
    noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://galexc.net').href;
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="theme-color" content="#f4eee4" />
        <meta name="description" content={description} />
        <meta name="author" content="Gilman Callsen" />
        {noindex && <meta name="robots" content="noindex" />}
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content="GalexC" />
        <meta property="og:image" content="https://galexc.net/favicon.png" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/galexc-icon-2.svg" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body class="site-shell">
        <main>
            <slot />
        </main>
        <footer class="site-footer">
            <p>
                &copy; {new Date().getFullYear()}
                <a
                    href="https://galexc.me"
                    target="_blank"
                    rel="noreferrer noopener">Gilman Callsen</a
                >. All rights reserved.
            </p>
        </footer>
    </body>
</html>
