---
import { variantStudies } from '../lib/site-content';

interface Props {
    current?: string;
}

const { current } = Astro.props;
---

<nav class="study-links" aria-label="Design studies">
    <a class:list={['study-links__home', !current && 'active']} href="/">
        Home
    </a>
    {
        variantStudies.map((study) => (
            <a
                class:list={['study-links__item', current === study.slug && 'active']}
                href={`/${study.slug}`}
            >
                <span class="study-links__index">{study.index}</span>
                <span>{study.name}</span>
            </a>
        ))
    }
</nav>
