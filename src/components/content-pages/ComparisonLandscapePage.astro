---
import ComparisonConstellationMap from '../graphics/ComparisonConstellationMap.astro';
import ContentPageHero from './ContentPageHero.astro';

const cards = [
    [
        'GalexC',
        'Best understood as a personal operating environment for shaping, dispatch, review, and durable memory.',
    ],
    [
        'Claude Code',
        'Best understood as a powerful coding harness centered on an active repo session.',
    ],
    [
        'Hermes',
        'Optimizes for flexible skill-driven behavior and broader agentic autonomy.',
    ],
    ['OpenClaw', 'Represents a more open, hackable, autonomy-forward posture.'],
];

const workflow = [
    ['Shape', 'Define the work before anything runs.'],
    ['Dispatch', 'Send only what is bounded enough to trust.'],
    ['Review', 'Return through a PR or artifact with receipts.'],
    ['Keep', 'Store the useful result as durable context.'],
];
---

<div class="essay-page comparison-page">
    <ContentPageHero
        eyebrow="Comparisons / Comparison landscape"
        title="Where GalexC sits in the agent landscape."
        lede="GalexC overlaps with coding agents, autonomous harnesses, and other emerging AI systems, but it is not trying to be a generic assistant or a pure autonomy play. The point is a durable personal operating environment: operator-owned, reviewable, and built for real ongoing work."
    >
        <div slot="artifact" class="page-module">
            <ComparisonConstellationMap />
        </div>
        <div slot="aside" class="page-module content-aside compact-callout">
            <p class="eyebrow">Not a scorecard</p>
            <p>Center of gravity, not rankings.</p>
        </div>
    </ContentPageHero>

    <section class="comparison-cards comparison-open-grid">
        {
            cards.map(([title, body]) => (
                <article class="page-module comparison-open-card comparison-card">
                    <p class="eyebrow">Reference point</p>
                    <h2>{title}</h2>
                    <p>{body}</p>
                </article>
            ))
        }
    </section>

    <section class="page-module comparison-workflow-card workflow-ledger-card">
        <p class="eyebrow">Workflow shape</p>
        <div class="comparison-workflow-list comparison-workflow-list--signals">
            {
                workflow.map(([title, body]) => (
                    <div class="comparison-workflow-list__item">
                        <strong>{title}</strong>
                        <p>{body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-grid-two">
        <article class="page-module content-aside boundary-split">
            <p class="eyebrow">What GalexC is not</p>
            <ul>
                <li>Not just a chat shell with extra tools</li>
                <li>Not a generic SaaS copilot</li>
                <li>Not an agents-gone-wild framework</li>
            </ul>
        </article>
        <article class="page-module">
            <p class="eyebrow">Why the distinction matters</p>
            <p>
                If you want the fastest path to one interactive coding loop,
                other tools may be a more natural fit. If you want an
                operator-owned environment for shaping, execution, memory, and
                review, GalexC is aiming at that territory on purpose.
            </p>
        </article>
    </section>
</div>
