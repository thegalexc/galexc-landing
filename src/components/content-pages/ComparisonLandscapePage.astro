---
import ComparisonConstellationMap from '../graphics/ComparisonConstellationMap.astro';
import ContentPageHero from './ContentPageHero.astro';

const adjacentTools = [
    {
        name: 'Claude Code',
        optimizesFor: 'Fast interactive coding inside an active repo session.',
        givesUp:
            'Broader durable operating environment and long-running personal system posture.',
    },
    {
        name: 'Hermes',
        optimizesFor:
            'Flexible skill-driven behavior and wider agentic autonomy.',
        givesUp:
            'The same emphasis on bounded operator review as the product center.',
    },
    {
        name: 'OpenClaw',
        optimizesFor: 'Hackable autonomy-forward experimentation.',
        givesUp: 'A warmer, more governed day-to-day working environment.',
    },
];

const workflow = [
    ['01', 'Shape', 'Define the work before anything runs.'],
    ['02', 'Dispatch', 'Send only what is bounded enough to trust.'],
    ['03', 'Review', 'Return through a PR or artifact with receipts.'],
    ['04', 'Keep', 'Store the useful result as durable context.'],
];

const fit = {
    best: [
        'You want an operator-owned environment rather than a single agent surface',
        'You care about routing, review, and memory as much as raw execution',
        'You want a personal AI system that can become more your own over time',
    ],
    notFor: [
        'You only want the fastest possible one-session coding loop',
        'You want unbounded autonomy to roam without an explicit review surface',
        'You want a generic SaaS copilot more than an owned system',
    ],
};
---

<div class="grid gap-10">
    <ContentPageHero
        eyebrow="Comparisons"
        title="Comparison Landscape"
        lede="GalexC overlaps with coding agents, autonomous harnesses, and other emerging AI systems, but it is not trying to be a generic assistant or a pure autonomy play. The point is a durable personal operating environment: operator-owned, reviewable, and built for real ongoing work."
    >
        <div
            slot="aside"
            class="grid gap-2.5 pl-5 border-l-2 border-l-[rgba(21,74,122,0.18)] content-start"
        >
            <p class="eyebrow">Not a scorecard</p>
            <p
                class="m-0 font-[Cormorant_Garamond,serif] text-[1.65rem] leading-[1.05]"
            >
                Center of gravity, not rankings.
            </p>
        </div>
    </ContentPageHero>

    <section
        class="grid gap-3.5 p-[1.15rem_1.2rem] rounded-[1.35rem_0.95rem_1.15rem_0.92rem] border border-[rgba(120,113,108,0.14)] shadow-[0_10px_28px_rgba(43,36,29,0.04)]"
        style="background: linear-gradient(180deg, rgba(255,255,255,0.44), rgba(251,247,241,0.52)), repeating-linear-gradient(180deg, rgba(120,113,108,0.038) 0, rgba(120,113,108,0.038) 1px, transparent 1px, transparent 33px);"
    >
        <p class="eyebrow">Landscape axes</p>
        <ComparisonConstellationMap />
        <p class="m-0 text-[#6a5e52] text-[0.93rem] leading-relaxed">
            Refined around two clearer dimensions: X axis is observability and
            durability, while Y axis is harness hackability.
        </p>
    </section>

    <section
        class="grid gap-4 items-start md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]"
    >
        <article
            class="grid gap-3.5 border-t border-t-[rgba(120,113,108,0.14)] pt-3.5"
            style="background: linear-gradient(180deg, rgba(248,243,236,0.78), rgba(255,255,255,0.5));"
        >
            <p class="eyebrow">GalexC posture</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]"
            >
                Personal operating environment
            </h2>
            <p>
                GalexC is strongest when the problem is not merely executing one
                task, but building a durable relationship between shaping,
                dispatch, review, and retained knowledge.
            </p>
            <div
                class="grid gap-3 mt-1.5 grid-cols-[repeat(auto-fit,minmax(14rem,1fr))]"
            >
                <div>
                    <strong>Optimizes for</strong>
                    <p>
                        Ownership, bounded execution, reviewable outputs, and a
                        system that compounds over time.
                    </p>
                </div>
                <div>
                    <strong>Gives up</strong>
                    <p>
                        Some of the immediacy and simplicity of a narrower,
                        single-surface tool.
                    </p>
                </div>
            </div>
        </article>

        <aside
            class="grid gap-0 pl-5 border-l-2 border-l-[rgba(21,74,122,0.18)]"
        >
            <p class="eyebrow">Adjacent tools</p>
            {
                adjacentTools.map((tool, i) => (
                    <div
                        class:list={[
                            'grid gap-1.5 py-4 border-t border-t-[rgba(120,113,108,0.12)]',
                            i === 0 && 'border-t-0',
                        ]}
                    >
                        <p class="m-0 font-[Cormorant_Garamond,serif] text-2xl leading-none text-[#2b241d]">
                            {tool.name}
                        </p>
                        <p>
                            <strong>Optimizes for:</strong> {tool.optimizesFor}
                        </p>
                        <p>
                            <strong>Gives up:</strong> {tool.givesUp}
                        </p>
                    </div>
                ))
            }
        </aside>
    </section>

    <section
        class="grid gap-3.5 pt-3.5 border-t border-t-[rgba(120,113,108,0.14)]"
    >
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <p class="eyebrow">Workflow shape</p>
                <h2
                    class="mt-1 font-[Cormorant_Garamond,serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    Method over feature matrix
                </h2>
            </div>
            <p class="m-0 text-[#6a5e52] text-[0.93rem] leading-relaxed">
                The distinction becomes clearest once the work has to come back
                through review.
            </p>
        </div>
        <div
            class="grid gap-3.5 grid-cols-[repeat(auto-fit,minmax(12rem,1fr))]"
        >
            {
                workflow.map(([code, title, body]) => (
                    <div class="grid gap-2 p-4 rounded-2xl border border-[rgba(120,113,108,0.14)] bg-[rgba(255,255,255,0.42)]">
                        <span class="font-[IBM_Plex_Mono,monospace] text-[0.68rem] tracking-[0.12em] uppercase text-[#6f6255]">
                            {code}
                        </span>
                        <strong>{title}</strong>
                        <p>{body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="grid gap-4 items-start md:grid-cols-2">
        <article
            class="grid gap-3.5 border-t border-t-[rgba(120,113,108,0.14)] pt-3.5"
        >
            <p class="eyebrow">Best fit</p>
            <ul class="m-0 p-0 list-none grid gap-2.5">
                {fit.best.map((item) => <li>{item}</li>)}
            </ul>
        </article>
        <article
            class="grid gap-3.5 border-t border-t-[rgba(120,113,108,0.14)] pt-3.5 bg-[rgba(248,243,236,0.72)]"
        >
            <p class="eyebrow">Not for</p>
            <ul class="m-0 p-0 list-none grid gap-2.5">
                {fit.notFor.map((item) => <li>{item}</li>)}
            </ul>
        </article>
    </section>
</div>
