---
import DesignProofPlate from '../graphics/DesignProofPlate.astro';
import ContentPageHero from './ContentPageHero.astro';

const doctrine = [
    ['Warm, not nostalgic', 'Human and held, not retro for its own sake.'],
    [
        'Serif for thought',
        'Mono keeps structure visible while prose carries the argument.',
    ],
    ['Blue is a signal', 'Accent where attention matters, not as a wash.'],
    [
        'Whitespace is operational',
        'Breathing room creates pacing and room for judgment.',
    ],
    ['Reveal, do not barrage', 'Information should unfold in layers.'],
    [
        'Composition over templating',
        'Each page should look arranged for its subject.',
    ],
];

const contrast = {
    dashboard: [
        'Dense panes and constant controls',
        'Urgent prompts competing for attention',
        'Little room for notes or hierarchy to breathe',
    ],
    editorial: [
        'Quiet hierarchy and readable measures',
        'Room for notes, context, and pause',
        'Accent only where attention is earned',
    ],
};

const anchoredDoctrine = doctrine.slice(0, 4);
---

<div class="grid gap-[2.4rem]">
    <ContentPageHero
        eyebrow="Principles / Design philosophy"
        title="Design should feel authored."
        lede="GalexC should not feel like an AI dashboard that borrowed nicer type. It should feel composed, editorial, and quietly deliberate - more like a publication, notebook, or field manual than a SaaS shell. That choice is not cosmetic. It signals how the product thinks."
    />

    <section
        class="grid gap-[0.9rem] rounded-[1.35rem_0.95rem_1.15rem_0.92rem] border border-[rgba(120,113,108,0.14)] bg-[linear-gradient(180deg,rgba(255,255,255,0.44),rgba(251,247,241,0.52)),repeating-linear-gradient(180deg,rgba(120,113,108,0.038)_0,rgba(120,113,108,0.038)_1px,transparent_1px,transparent_33px)] px-[1.2rem] py-[1.15rem] shadow-[0_10px_28px_rgba(43,36,29,0.04)]"
    >
        <p class="eyebrow">Editorial specimen</p>
        <DesignProofPlate />
    </section>

    <section
        class="grid gap-4 items-start max-md:grid-cols-1 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]"
    >
        <article
            class="grid gap-[0.45rem] rounded-2xl border border-[rgba(120,113,108,0.14)] border-t-[rgba(120,113,108,0.14)] bg-[rgba(248,243,236,0.72)] p-4 pt-[0.9rem]"
        >
            <p class="eyebrow">Dashboard instinct</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]"
            >
                Busy by default
            </h2>
            <ul class="grid gap-[0.65rem]">
                {contrast.dashboard.map((item) => <li>{item}</li>)}
            </ul>
        </article>
        <article
            class="grid gap-[0.45rem] rounded-2xl border border-[rgba(21,74,122,0.18)] bg-[rgba(255,255,255,0.6)] p-4 pt-[0.9rem]"
        >
            <p class="eyebrow">Authored surface</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]"
            >
                Composed enough to think inside
            </h2>
            <ul class="grid gap-[0.65rem]">
                {contrast.editorial.map((item) => <li>{item}</li>)}
            </ul>
        </article>
    </section>

    <section class="grid gap-[0.9rem]">
        <div
            class="grid gap-[0.6rem] md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <p class="eyebrow">Surface as posture</p>
                <h2
                    class="mt-[0.3rem] font-[Cormorant_Garamond,serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    Visual decisions map to operator posture
                </h2>
            </div>
        </div>
        <div
            class="grid items-start gap-4 md:grid-cols-[repeat(2,minmax(0,1fr))]"
        >
            <article
                class="grid content-start gap-[0.9rem] rounded-[1.35rem_0.95rem_1.15rem_0.92rem] border border-[rgba(120,113,108,0.14)] bg-[linear-gradient(180deg,rgba(255,255,255,0.44),rgba(251,247,241,0.52)),repeating-linear-gradient(180deg,rgba(120,113,108,0.038)_0,rgba(120,113,108,0.038)_1px,transparent_1px,transparent_33px)] px-[1.2rem] py-[1.15rem] shadow-[0_10px_28px_rgba(43,36,29,0.04)]"
            >
                <p class="eyebrow">Specimen spread</p>
                <h3
                    class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.8rem,3vw,2.5rem)] leading-none"
                >
                    A page should feel composed enough to think inside.
                </h3>
                <div class="h-px w-[min(14rem,100%)] bg-[rgba(21,74,122,0.24)]">
                </div>
                <p>
                    Big serif hierarchy for thought. A measured reading column
                    for the actual argument. Small mono notes for structure.
                    Blue only where emphasis is earned.
                </p>
            </article>
            <aside
                class="grid gap-[0.6rem] border-l-2 border-l-[rgba(21,74,122,0.18)] pl-[1.15rem]"
            >
                <p class="eyebrow">Anatomy</p>
                <div
                    class="grid gap-[0.25rem] border-t border-t-[rgba(120,113,108,0.14)] pt-[0.8rem]"
                >
                    <strong>Breathing room</strong>
                    <p>
                        Whitespace suggests confidence and pacing, not
                        emptiness.
                    </p>
                </div>
                <div
                    class="grid gap-[0.25rem] border-t border-t-[rgba(120,113,108,0.14)] pt-[0.8rem]"
                >
                    <strong>Quiet rule</strong>
                    <p>
                        Thin dividers keep rhythm visible without turning the
                        page into chrome.
                    </p>
                </div>
                <div
                    class="grid gap-[0.25rem] border-t border-t-[rgba(120,113,108,0.14)] pt-[0.8rem]"
                >
                    <strong>Marginal note</strong>
                    <p>
                        Micro-labels let the system explain itself without
                        shouting.
                    </p>
                </div>
                <div
                    class="grid gap-[0.25rem] border-t border-t-[rgba(120,113,108,0.14)] pt-[0.8rem]"
                >
                    <strong>Accent discipline</strong>
                    <p>
                        The blue only appears where attention or interaction
                        truly matters.
                    </p>
                </div>
            </aside>
        </div>
    </section>

    <section
        class="grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(280px,0.7fr)]"
    >
        <article class="grid gap-[0.9rem]">
            <p class="eyebrow">Why this matters</p>
            <p>
                An authored, editorial, calm, durable surface communicates the
                same values as the system beneath it: bounded work over chaos,
                legibility over novelty, memory over ephemera, and confidence
                without noise. The interface should feel kept, not consumed.
            </p>
        </article>
        <aside
            class="grid gap-0 border-l-2 border-l-[rgba(21,74,122,0.18)] pl-[1.15rem]"
        >
            <p class="eyebrow">Visual doctrine</p>
            {
                anchoredDoctrine.map(([title, body], i) => (
                    <div
                        class:list={[
                            'grid gap-[0.2rem] py-[0.95rem]',
                            i > 0 &&
                                'border-t border-t-[rgba(120,113,108,0.12)]',
                        ]}
                    >
                        <p class="font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]">
                            {title}
                        </p>
                        <p>{body}</p>
                    </div>
                ))
            }
        </aside>
    </section>
</div>
