---
import ArchitectureSeamDiagram from '../graphics/ArchitectureSeamDiagram.astro';
import ContentPageHero from './ContentPageHero.astro';

const facts = ['Start from a seed', 'Own the fork', 'Replace with intent'];

const layers = [
    {
        title: 'Seed system',
        body: 'GalexC begins with a working base, currently galexc-starter-pack and likely soon galexc-seed. It gives you a coherent operating idea and a live environment on day one rather than asking you to assemble every primitive yourself.',
        tags: ['coherent base', 'working day one', 'teachable'],
    },
    {
        title: 'Interaction surfaces',
        body: 'Durable sessions, tasks, async dispatch, scheduled work, workstation Pi, and intercom create the first serious interface between the operator and the system.',
        tags: ['live shaping', 'workflow control', 'reviewable'],
    },
    {
        title: 'Supporting services',
        body: 'Storage, search, routing, notifications, and background services keep context intact and make long-running work observable instead of opaque.',
        tags: ['continuity', 'visibility', 'durable memory'],
    },
    {
        title: 'Replaceable internals',
        body: 'Postgres, Python services, schedulers, and other implementation choices are defaults, not dogma. The system is meant to tolerate real substitution.',
        tags: ['replaceable', 'not sacred', 'operator choice'],
    },
    {
        title: 'Personal environment',
        body: 'After the fork, the stack should stop feeling borrowed. It becomes your own professional-grade personal AI environment, shaped around your standards and cadence.',
        tags: ['your cadence', 'long-term ownership', 'compounding leverage'],
    },
];

const replaceabilityLedger = [
    {
        layer: 'Seed model',
        defaultState:
            'A coherent starting point with real workflows already in place',
        canChange: 'Yes, once the operating idea is understood',
        consequence:
            'You keep the parts that teach well and replace the parts that do not fit.',
    },
    {
        layer: 'Interaction surfaces',
        defaultState:
            'Session, task, and dispatch rhythms that already work together',
        canChange: 'Yes, if your preferred working cadence is different',
        consequence:
            'The surface changes, but the review boundary still matters.',
    },
    {
        layer: 'Infra services',
        defaultState:
            'Opinionated storage, search, and background-service defaults',
        canChange: 'Yes, service by service',
        consequence:
            'The substrate can evolve without forcing a total rewrite of the system.',
    },
    {
        layer: 'Implementation details',
        defaultState:
            'Current languages, libraries, and internal service boundaries',
        canChange: 'Yes, aggressively',
        consequence:
            'You can modernize internals without giving up the operator model.',
    },
];

const progression = [
    {
        code: '01',
        title: 'Start coherent',
        body: 'Begin with a working system that already knows how to route work, preserve context, and return results for review.',
    },
    {
        code: '02',
        title: 'Learn by use',
        body: 'Operate the seed long enough to understand which surfaces feel natural and which assumptions you want to challenge.',
    },
    {
        code: '03',
        title: 'Diverge deliberately',
        body: 'Replace infrastructure, services, or workflows where your needs, standards, or taste genuinely differ.',
    },
    {
        code: '04',
        title: 'Own the result',
        body: 'The fork becomes your environment, not a copy waiting for upstream permission.',
    },
];

const loopSteps = [
    'Define the work',
    'Route the right context',
    'Pick the execution mode',
    'Run with clear bounds',
    'Review what returns',
    'Keep the durable gain',
];

const layerItems = [
    {
        label: 'Repos and artifacts',
        body: 'Real source material, real file history, and real ownership. The system starts from things that matter.',
    },
    {
        label: 'Tasks and intent',
        body: 'A durable record of what the work is, why it matters, and what done means before execution begins.',
    },
    {
        label: 'Methods and skills',
        body: 'Prompts, skills, and recurring workflows that make good operating habits reusable instead of improvised.',
    },
    {
        label: 'Durable services',
        body: 'Search, state, notifications, dispatch, and observability that keep the loop from collapsing into scrollback.',
    },
    {
        label: 'Review surfaces',
        body: 'PRs, artifacts, and bounded outputs that let the human decide what becomes real.',
    },
];

const trustItems = [
    'Bounded execution over vague autonomy',
    'Reviewable returns over hidden action',
    'Searchable state over disposable chat history',
    'Private infrastructure over casual exposure',
    'Recoverable systems with receipts',
];
---

<div class="grid gap-10">
    <ContentPageHero
        eyebrow="System"
        title="Architecture overview"
        lede="GalexC starts from a seed system that already knows how to route work, preserve context, run background execution, and return outputs through review. Today that seed is galexc-starter-pack and likely soon galexc-seed. The important point is not the exact stack. The important point is that you begin with a coherent operating model, then take full ownership and reshape the system around your own needs."
    >
        <ul
            slot="aside"
            class="m-0 grid list-none gap-2 border-t border-stone-400/14 p-0 pt-2 font-['IBM_Plex_Mono',monospace] text-xs uppercase tracking-[0.12em] text-[#6f6255]"
        >
            {facts.map((fact) => <li>{fact}</li>)}
        </ul>
    </ContentPageHero>

    <section
        class="grid gap-3.5 rounded-[1.35rem_0.95rem_1.15rem_0.92rem] border border-stone-400/14 bg-[linear-gradient(180deg,rgba(255,255,255,0.44),rgba(251,247,241,0.52)),repeating-linear-gradient(180deg,rgba(120,113,108,0.038)_0,rgba(120,113,108,0.038)_1px,transparent_1px,transparent_33px)] p-5 shadow-[0_10px_28px_rgba(43,36,29,0.04)]"
    >
        <h2 class="eyebrow">System seam</h2>
        <ArchitectureSeamDiagram />
    </section>

    <section class="grid gap-3.5 border-t border-stone-400/14 pt-3.5">
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <h2 class="eyebrow">System at a glance</h2>
                <h2
                    class="mt-1 font-['Cormorant_Garamond',serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    A working base meant to be inherited, then reshaped
                </h2>
            </div>
        </div>
        <div class="grid gap-3.5">
            {
                layers.map((layer, index) => (
                    <div
                        class:list={[
                            'grid gap-1.5 py-4 border-b border-stone-400/10',
                            index === layers.length - 1 &&
                                'pl-3.5 border-l-2 border-l-[rgba(21,74,122,0.24)] bg-[linear-gradient(90deg,rgba(21,74,122,0.05),transparent_62%)]',
                        ]}
                    >
                        <div class="grid gap-2">
                            <h3 class="m-0 font-['Cormorant_Garamond',serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]">
                                {layer.title}
                            </h3>
                            <div class="grid grid-cols-[repeat(auto-fit,minmax(9rem,max-content))] gap-2">
                                {layer.tags.map((tag) => (
                                    <span class="rounded-full bg-[rgba(21,74,122,0.08)] px-2 py-1 font-['IBM_Plex_Mono',monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#123c62]">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                        <p>{layer.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="grid gap-3.5 border-t border-stone-400/14 pt-3.5">
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <p class="eyebrow">Replaceability ledger</p>
                <h2
                    class="mt-1 font-['Cormorant_Garamond',serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    What should stay coherent, and what can change freely
                </h2>
            </div>
            <p class="m-0 text-[0.93rem] leading-relaxed text-[#6a5e52]">
                The seed is important because it teaches. The exact
                implementation is allowed to move.
            </p>
        </div>
        <div class="grid gap-0">
            {
                replaceabilityLedger.map((item, index) => (
                    <div
                        class:list={[
                            'grid gap-1.5 py-4',
                            index > 0 && 'border-t border-stone-400/12',
                        ]}
                    >
                        <p class="m-0 font-['Cormorant_Garamond',serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]">
                            {item.layer}
                        </p>
                        <p>
                            <strong>Default:</strong> {item.defaultState}
                        </p>
                        <p>
                            <strong>Can change:</strong> {item.canChange}
                        </p>
                        <p>
                            <strong>Consequence:</strong> {item.consequence}
                        </p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="grid gap-3.5">
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <p class="eyebrow">One path through the system</p>
                <h2
                    class="mt-1 font-['Cormorant_Garamond',serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    Start coherent, then diverge with judgment
                </h2>
            </div>
            <p class="m-0 text-[0.93rem] leading-relaxed text-[#6a5e52]">
                The seed is a starting posture, not a permanent boundary.
            </p>
        </div>
        <div
            class="grid gap-3.5 grid-cols-[repeat(auto-fit,minmax(12rem,1fr))]"
        >
            {
                progression.map((item) => (
                    <div class="grid gap-2 rounded-2xl border border-stone-400/14 bg-white/42 p-4">
                        <span class="font-['IBM_Plex_Mono',monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]">
                            {item.code}
                        </span>
                        <h3 class="m-0 font-['Cormorant_Garamond',serif] text-[clamp(1.8rem,3vw,2.45rem)] leading-none text-[#2b241d]">
                            {item.title}
                        </h3>
                        <p>{item.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2">
        <article class="grid gap-3.5">
            <h2 class="eyebrow">Why the system starts this way</h2>
            <p>
                The seed gives you a coherent philosophy and a working substrate
                before you begin customizing. That makes the system teachable.
                It lets you learn how to interact with your personal AI before
                you decide which parts to keep, replace, or extend. If you want
                to inherit my learnings and features through Parley, you can.
                You do not need to. Optional inheritance is useful only if it
                never overrides real ownership.
            </p>
        </article>
        <aside
            class="grid gap-2.5 border-l-2 border-l-[rgba(21,74,122,0.18)] pl-5"
        >
            <p class="eyebrow">Legend</p>
            <ul class="m-0 grid list-none gap-2.5 p-0">
                <li>
                    <strong>Center seam</strong> - shared context gets stitched into
                    a durable record before it moves onward
                </li>
                <li>
                    <strong>Stepped stack</strong> - each layer keeps the logic of
                    the system visible even as implementations change
                </li>
                <li>
                    <strong>Replaceability ledger</strong> - where ownership becomes
                    practical rather than rhetorical
                </li>
            </ul>
        </aside>
    </section>

    <section class="grid gap-3.5 border-t border-stone-400/14 pt-3.5">
        <h2 class="eyebrow">Operating loop</h2>
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <p class="m-0 text-[0.93rem] leading-relaxed text-[#6a5e52]">
                The product is the operating loop, not a single chat surface.
            </p>
        </div>
        <div class="flex flex-wrap gap-3">
            {
                loopSteps.map((step, index) => (
                    <>
                        <div class="rounded-full border border-stone-400/16 bg-white/52 px-3.5 py-2.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]">
                            {step}
                        </div>
                        {index < loopSteps.length - 1 && (
                            <div
                                class="h-px w-6 self-center bg-[rgba(21,74,122,0.28)]"
                                aria-hidden="true"
                            />
                        )}
                    </>
                ))
            }
        </div>
    </section>

    <section class="grid gap-3.5">
        <div
            class="grid gap-2.5 md:grid-cols-[minmax(0,1fr)_minmax(220px,0.36fr)] md:items-end"
        >
            <div>
                <p class="eyebrow">Built from durable primitives</p>
                <h2
                    class="mt-1 font-['Cormorant_Garamond',serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
                >
                    More operating environment than assistant
                </h2>
            </div>
            <p class="m-0 text-[0.93rem] leading-relaxed text-[#6a5e52]">
                The leverage comes from composition, not from pretending one
                model is the whole product.
            </p>
        </div>
        <div class="grid gap-3.5">
            {
                layerItems.map((item) => (
                    <div class="grid gap-1.5 border-t border-stone-400/14 pt-4">
                        <h3 class="m-0 font-['IBM_Plex_Mono',monospace] text-xs uppercase tracking-[0.12em] text-[#6f6255]">
                            {item.label}
                        </h3>
                        <p>{item.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section
        class="grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(280px,0.7fr)]"
    >
        <article class="grid gap-3.5">
            <h2 class="eyebrow">Why it matters</h2>
            <h2
                class="mt-1 font-['Cormorant_Garamond',serif] text-[clamp(2rem,3.6vw,3rem)] leading-[0.95] text-[#2b241d]"
            >
                A system that compounds
            </h2>
            <p>
                Useful context should accumulate instead of dissolving into
                scrollback. Methods should become reusable. Async work should
                return with enough structure that review becomes short and trust
                becomes earned. GalexC exists to help one person think better,
                execute faster, preserve continuity, and build real leverage
                without giving up ownership.
            </p>
        </article>
        <aside
            class="grid gap-2.5 border-l-2 border-l-[rgba(21,74,122,0.18)] pl-5"
        >
            <p class="eyebrow">Strong boundaries</p>
            <ul class="m-0 grid list-none gap-2.5 p-0">
                {trustItems.map((item) => <li>{item}</li>)}
            </ul>
        </aside>
    </section>
</div>
