---
import ContentPageHero from './ContentPageHero.astro';

const stackRows = [
    [
        'Pi.dev runtime',
        'Required',
        'GalexC seed ships as a Pi-based working environment.',
    ],
    [
        'Hub web UI',
        'Required',
        'Primary browser interface for visibility, review, and light interaction.',
    ],
    [
        'Postgres',
        'Required',
        'System state, tasks, durable records, and service-backed memory surfaces.',
    ],
    [
        'Dispatch worker',
        'Required',
        'Runs bounded async jobs outside the live session.',
    ],
    [
        'Intercom',
        'Required',
        'Message channel between sessions, jobs, and services.',
    ],
    [
        'ntfy',
        'Required',
        'Out-of-band notifications when work finishes or needs attention.',
    ],
    [
        'Search + indexing',
        'Required',
        'Makes docs, notes, and system state retrievable instead of lost in scrollback.',
    ],
    [
        'LM provider layer',
        'Pluggable',
        'Anthropic, OpenAI, Google, OpenRouter, LM Studio, or other providers.',
    ],
];

const wiring = [
    {
        title: 'Operator surfaces',
        body: 'Pi sessions and Hub are the main human control planes.',
    },
    {
        title: 'Coordination layer',
        body: 'Tasks, dispatch, intercom, and notifications coordinate work across live and async paths.',
    },
    {
        title: 'State layer',
        body: 'Postgres and search keep work durable, queryable, and reviewable.',
    },
    {
        title: 'Execution layer',
        body: 'Agents, jobs, and tools run against repos, files, services, and external APIs.',
    },
];

const nonNegotiables = [
    'You need a Pi-based local runtime, not only a chat UI.',
    'You need Postgres-backed durable state.',
    'You need the Hub web interface for review and operational visibility.',
    'You need async execution through dispatch, not only live sessions.',
    'You need notifications outside the terminal, currently through ntfy.',
];
---

<div class="grid gap-10 md:gap-12">
    <ContentPageHero
        eyebrow="System"
        title="Architecture overview"
        lede="GalexC seed is a wired system, not a prompt pack. The important question is not which model you use. The important question is whether you want the full stack required to run live sessions, async jobs, durable state, review surfaces, and notifications as one environment."
    />

    <section
        class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6 max-w-[56rem]"
    >
        <div class="grid gap-2.5">
            <p class="eyebrow">Non-negotiables</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                What the seed actually requires
            </h2>
        </div>
        <ul class="m-0 grid list-none gap-3 p-0">
            {
                nonNegotiables.map((item) => (
                    <li class="border-t border-t-[rgba(120,113,108,0.12)] pt-3 text-[#4f4438] leading-relaxed">
                        {item}
                    </li>
                ))
            }
        </ul>
    </section>

    <section class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6">
        <div class="grid gap-2.5 max-w-[44rem]">
            <p class="eyebrow">System wiring</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                How the seed is wired together
            </h2>
        </div>
        <div
            class="overflow-x-auto rounded-[1.2rem] border border-[rgba(120,113,108,0.14)] bg-[rgba(255,252,247,0.42)] p-4 md:p-5"
        >
            <pre
                class="m-0 whitespace-pre-wrap font-[IBM_Plex_Mono,monospace] text-[0.72rem] leading-[1.7] text-[#4f4438] md:text-[0.78rem]">[ operator ]
   ├─ Pi session
   ├─ Hub web
   └─ ntfy notifications
          │
          ▼
[ coordination ]
   ├─ tasks
   ├─ dispatch
   ├─ intercom
   └─ scheduled jobs
          │
          ▼
[ durable state ]
   ├─ Postgres
   └─ search / indexes
          │
          ▼
[ execution targets ]
   ├─ local repos and files
   ├─ background agents
   ├─ external APIs
   └─ model providers / LM Studio</pre>
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            {
                wiring.map((item) => (
                    <article class="grid gap-2 border-t border-t-[rgba(120,113,108,0.12)] pt-3">
                        <h3 class="m-0 font-[IBM_Plex_Mono,monospace] text-[0.68rem] tracking-[0.12em] uppercase text-[#6f6255]">
                            {item.title}
                        </h3>
                        <p class="m-0 text-[#4f4438] leading-relaxed">
                            {item.body}
                        </p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6">
        <div class="grid gap-2.5 max-w-[44rem]">
            <p class="eyebrow">Stack table</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                Required pieces vs. pluggable pieces
            </h2>
        </div>
        <div
            class="grid grid-cols-[minmax(0,1.1fr)_120px_minmax(0,2fr)] gap-0 border-t border-l border-[rgba(120,113,108,0.12)] max-md:grid-cols-1"
        >
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                Component
            </div>
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                Status
            </div>
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                Role in the seed
            </div>
            {
                stackRows.map(([component, status, role]) => (
                    <>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#2b241d]">
                            {component}
                        </div>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#5b4f43]">
                            {status}
                        </div>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#5b4f43]">
                            {role}
                        </div>
                    </>
                ))
            }
        </div>
    </section>
</div>
