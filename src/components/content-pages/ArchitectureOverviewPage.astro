---
import ArchitectureSeamDiagram from '../graphics/ArchitectureSeamDiagram.astro';
import ContentPageHero from './ContentPageHero.astro';

const facts = ['Seed first', 'Replace any layer', 'Fork and own it'];

const layers = [
    {
        title: 'Seed layer',
        body: 'GalexC starts from galexc-starter-pack, likely soon galexc-seed, which establishes the foundational interaction model and working system.',
        tags: ['default', 'teachable base', 'owned fork'],
    },
    {
        title: 'Interaction layer',
        body: 'Durable sessions, tasks, async dispatch, scheduled work, workstation Pi, and intercom create the first serious operating surface.',
        tags: ['live shaping', 'workflow control', 'review path'],
    },
    {
        title: 'Services',
        body: 'Storage, search, routing, notifications, and background services provide continuity and visibility.',
        tags: ['durable memory', 'observability', 'continuity'],
    },
    {
        title: 'Replaceable implementation',
        body: 'Postgres, Python services, schedulers, and other internals are defaults, not commandments. Swap them if your system wants something else.',
        tags: ['replaceable', 'not sacred', 'operator choice'],
    },
    {
        title: 'Personal evolution',
        body: 'Once forked, the stack becomes your own professional-grade personal AI environment rather than a centrally maintained product.',
        tags: ['your cadence', 'long-term ownership', 'compounding system'],
    },
];

const replaceabilityLedger = [
    {
        layer: 'Seed',
        defaultState: 'Coherent starting point',
        canChange: 'Yes, after the operator understands the working base',
        consequence:
            'You preserve the operating idea while making the system truly your own.',
    },
    {
        layer: 'Interaction layer',
        defaultState: 'Durable session and dispatch workflow',
        canChange: 'Yes, if you want a different rhythm or surface',
        consequence:
            'The cadence changes, but the review boundary still matters.',
    },
    {
        layer: 'Services',
        defaultState: 'Opinionated infra defaults',
        canChange: 'Yes, service by service',
        consequence:
            'The substrate shifts without forcing a full product rewrite.',
    },
    {
        layer: 'Implementation',
        defaultState: 'Current languages and internal services',
        canChange: 'Yes, aggressively',
        consequence:
            'You can replace internals without giving up ownership of the operating model.',
    },
];

const progression = [
    {
        code: '01',
        title: 'Seed',
        body: 'Start from a coherent base instead of assembling every primitive from scratch.',
    },
    {
        code: '02',
        title: 'Adapt',
        body: 'Replace or reshape infrastructure, services, and workflows to fit your own needs.',
    },
    {
        code: '03',
        title: 'Operate',
        body: 'Build a real cadence with your AI so the system stays useful, maintained, and personal over time.',
    },
    {
        code: '04',
        title: 'Own',
        body: 'The fork stops feeling borrowed and starts behaving like your environment.',
    },
];

const loopSteps = [
    'Define work',
    'Route context',
    'Choose workflow',
    'Run in the right mode',
    'Review output',
    'Keep what matters',
];

const layerItems = [
    {
        label: 'Repos',
        body: 'Source material that matters. Real files, real history, real ownership.',
    },
    {
        label: 'Tasks',
        body: 'Scoped intent and what done means before execution begins.',
    },
    {
        label: 'Methods',
        body: 'Prompts and skills that turn good approaches into reusable workflow.',
    },
    {
        label: 'Services',
        body: 'Search, state, notifications, forge, and observability that keep the loop durable.',
    },
    {
        label: 'Review',
        body: 'PRs and artifacts that let the human decide what becomes real.',
    },
];

const trustItems = [
    'Bounded execution over vague autonomy',
    'Search before browse',
    'Reviewable outputs only',
    'Private by default service exposure',
    'Recoverable systems with receipts',
];
---

<div class="essay-page architecture-page">
    <ContentPageHero
        eyebrow="System"
        title="Architecture Overview"
        lede="GalexC begins with a seed system, currently galexc-starter-pack and likely becoming galexc-seed. This establishes the foundational interaction model and a working system from day one. You get durable interaction layers, tasks, async dispatch, scheduled work, a workstation Pi environment aligned with dispatched agents, and core communications primitives like intercom. From there, you take full ownership and shape the system around your own needs."
    >
        <ul slot="aside" class="page-note-list">
            {facts.map((fact) => <li>{fact}</li>)}
        </ul>
    </ContentPageHero>

    <section class="page-module specimen-frame">
        <h2 class="eyebrow">System seam</h2>
        <ArchitectureSeamDiagram />
    </section>

    <section class="page-module architecture-plate">
        <div class="module-heading-row">
            <div>
                <h2 class="eyebrow">System at a glance</h2>
                <h2 class="page-section-title">
                    A stack meant to be inherited, then changed
                </h2>
            </div>
        </div>
        <div class="architecture-bands architecture-bands-stepped">
            {
                layers.map((layer, index) => (
                    <div
                        class:list={[
                            'architecture-band',
                            index === layers.length - 1 &&
                                'architecture-band-active',
                        ]}
                    >
                        <div class="architecture-band__header">
                            <h3>{layer.title}</h3>
                            <div class="architecture-band__tags">
                                {layer.tags.map((tag) => (
                                    <span>{tag}</span>
                                ))}
                            </div>
                        </div>
                        <p>{layer.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-module architecture-ledger-card">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">Replaceability ledger</p>
                <h2 class="page-section-title">
                    What is fixed, what is optional
                </h2>
            </div>
            <p class="page-caption">
                The seed matters. The exact implementation does not have to
                stay.
            </p>
        </div>
        <div class="architecture-ledger">
            {
                replaceabilityLedger.map((item) => (
                    <div class="architecture-ledger__row">
                        <p class="architecture-ledger__layer">{item.layer}</p>
                        <p>
                            <strong>Default:</strong> {item.defaultState}
                        </p>
                        <p>
                            <strong>Can change:</strong> {item.canChange}
                        </p>
                        <p>
                            <strong>Consequence:</strong> {item.consequence}
                        </p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-module flow-module">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">One path through the system</p>
                <h2 class="page-section-title">
                    Start coherent, then diverge deliberately
                </h2>
            </div>
            <p class="page-caption">
                The seed is the beginning, not the boundary.
            </p>
        </div>
        <div class="architecture-progression">
            {
                progression.map((item) => (
                    <div class="architecture-progression__item">
                        <span class="architecture-progression__code">
                            {item.code}
                        </span>
                        <h3>{item.title}</h3>
                        <p>{item.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-grid-two">
        <article class="page-module">
            <h2 class="eyebrow">Why the system starts this way</h2>
            <p>
                The seed gives you a coherent philosophy and a working substrate
                before you begin customizing. That makes the system teachable.
                It lets you learn how to interact with your personal AI before
                you decide which parts to keep, replace, or extend. If you want
                my learnings and features through Parley, you can use them. You
                do not need to. The system is designed so optional inheritance
                never overrides actual ownership.
            </p>
        </article>
        <aside class="page-module content-aside legend-card">
            <p class="eyebrow">Legend</p>
            <ul class="legend-card__list">
                <li>
                    <strong>Center seam</strong> - shared context gets stitched into
                    a durable record before it moves onward
                </li>
                <li>
                    <strong>Stepped stack</strong> - each layer keeps the logic of
                    the system visible even as implementations change
                </li>
                <li>
                    <strong>Replaceability ledger</strong> - where ownership becomes
                    practical rather than rhetorical
                </li>
            </ul>
        </aside>
    </section>

    <section class="page-module operating-loop-ledger">
        <h2 class="eyebrow">Operating loop</h2>
        <div class="module-heading-row">
            <p class="page-caption">
                The product is the loop, not a single assistant.
            </p>
        </div>
        <div class="loop-diagram">
            {
                loopSteps.map((step, index) => (
                    <>
                        <div class="loop-step">{step}</div>
                        {index < loopSteps.length - 1 && (
                            <div class="loop-connector" aria-hidden="true" />
                        )}
                    </>
                ))
            }
        </div>
    </section>

    <section class="page-module stack-module">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">Built from durable primitives</p>
                <h2 class="page-section-title">
                    More operating environment than assistant
                </h2>
            </div>
            <p class="page-caption">
                The leverage comes from composition, not from pretending one
                model is the whole product.
            </p>
        </div>
        <div class="layer-stack">
            {
                layerItems.map((item) => (
                    <div class="layer-stack__item">
                        <h3 class="layer-stack__label">{item.label}</h3>
                        <p>{item.body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-grid-two page-grid-two-wide-right">
        <article class="page-module">
            <h2 class="eyebrow">Why it matters</h2>
            <h2 class="page-section-title">A system that compounds</h2>
            <p>
                Useful context should accumulate instead of dissolving into
                scrollback. Methods should become reusable. Async work should
                return with enough structure that review becomes short and trust
                becomes earned. GalexC exists to help one person think better,
                execute faster, preserve continuity, and build real leverage
                without giving up ownership.
            </p>
        </article>
        <aside class="page-module content-aside trust-panel">
            <p class="eyebrow">Strong boundaries</p>
            <ul class="trust-panel__list">
                {trustItems.map((item) => <li>{item}</li>)}
            </ul>
        </aside>
    </section>
</div>
