---
import OperatorOrbitDiagram from '../graphics/OperatorOrbitDiagram.astro';
import ContentPageHero from './ContentPageHero.astro';

const ledger = [
    {
        actor: 'Human',
        owns: 'Intent, standards, approvals, and the right to reshape the system',
        goodFor:
            'Deciding what matters, what gets delegated, and what kind of personal AI this should become',
        avoid: 'Treating the seed as a fixed product or outsourcing irreversible judgment',
    },
    {
        actor: 'Session',
        owns: 'Learning, shaping, debugging, and steering in real time',
        goodFor:
            'Figuring out how you actually want to interact with your system',
        avoid: 'Pretending exploration is already a finished workflow',
    },
    {
        actor: 'Dispatch',
        owns: 'Bounded background execution',
        goodFor: 'Scoped async work once the task is clear enough to hand off',
        avoid: 'Open-ended autonomy without review or a clear source of truth',
    },
    {
        actor: 'Seed + services',
        owns: 'Durability, continuity, and maintenance scaffolding',
        goodFor:
            'Tasks, intercom, scheduled sweeps, version checks, notifications, and shared operational memory',
        avoid: 'Standing in for operator taste or dictating one permanent stack',
    },
];

const decisionRows = [
    {
        mode: 'Stay in session',
        useWhen:
            'You are still shaping the work, testing assumptions, or using taste and judgment live.',
        returnSurface: 'The active session itself',
        output: 'A tighter brief, clearer constraints, or a direct edit',
    },
    {
        mode: 'Dispatch it',
        useWhen:
            'The task is bounded enough to run unattended and come back through review.',
        returnSurface: 'A PR, artifact, or structured report',
        output: 'Background execution with receipts and a review surface',
    },
];

const serviceGroups = [
    {
        title: 'Planning',
        items: ['Tasks', 'Pi workstation'],
    },
    {
        title: 'Execution',
        items: ['Dispatch', 'Intercom'],
    },
    {
        title: 'Upkeep',
        items: ['Scheduled jobs', 'Notifications'],
    },
    {
        title: 'Inheritance',
        items: ['Parley'],
    },
];

const flowSteps = [
    ['01', 'Seed the base', 'Start from a working system, not a blank shell.'],
    ['02', 'Shape live', 'Use the session to clarify scope and standards.'],
    ['03', 'Run bounded work', 'Dispatch only what can return cleanly.'],
    ['04', 'Review the return', 'Accept, reject, or revise with receipts.'],
    ['05', 'Keep the learning', 'Let useful methods and context compound.'],
];
---

<div class="essay-page operator-page">
    <ContentPageHero
        eyebrow="System / Operator model"
        title="The operator model is meant to become personal."
        lede="GalexC is not only a software stack. It is a way to learn how to work with a personal AI system that you actually own. The seed gives you real structure on day one, but the goal is not to keep everyone on Gilman's preferred setup. The goal is to help you and your AI settle into a cadence that matches your own needs, constraints, and taste."
    >
        <div slot="aside" class="page-module content-aside compact-callout">
            <p class="eyebrow">Trust model</p>
            <p>
                GalexC delegates execution, but the operator owns the system and
                its evolution.
            </p>
        </div>
    </ContentPageHero>

    <section class="page-module specimen-frame">
        <p class="eyebrow">Responsibility map</p>
        <OperatorOrbitDiagram />
    </section>

    <section class="page-module">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">Responsibility ledger</p>
                <h2 class="page-section-title">
                    A system with named responsibilities
                </h2>
            </div>
        </div>
        <div class="responsibility-ledger">
            {
                ledger.map((item) => (
                    <article class="responsibility-row">
                        <p class="responsibility-row__actor">{item.actor}</p>
                        <div class="responsibility-row__body">
                            <p>
                                <strong>Owns:</strong> {item.owns}
                            </p>
                            <p>
                                <strong>Good for:</strong> {item.goodFor}
                            </p>
                            <p>
                                <strong>Should not do:</strong> {item.avoid}
                            </p>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="page-module flow-band flow-band-timeline flow-band-open">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">Control flow</p>
                <h2 class="page-section-title">How the cadence settles</h2>
            </div>
        </div>
        <div class="flow-timeline flow-timeline--procedural">
            {
                flowSteps.map(([code, label, body]) => (
                    <div class="flow-timeline__item">
                        <span class="flow-timeline__code">{code}</span>
                        <p class="flow-timeline__title">{label}</p>
                        <p>{body}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="page-module operator-decision-ledger">
        <div class="module-heading-row">
            <div>
                <p class="eyebrow">Routing decision</p>
                <h2 class="page-section-title">
                    When to stay live, when to dispatch
                </h2>
            </div>
            <p class="page-caption">
                The real operating habit is choosing the right execution mode.
            </p>
        </div>
        <div class="operator-decision-table">
            <div class="operator-decision-table__header">Mode</div>
            <div class="operator-decision-table__header">Use when</div>
            <div class="operator-decision-table__header">Returns through</div>
            <div class="operator-decision-table__header">Likely output</div>
            {
                decisionRows.map((row) => (
                    <>
                        <div class="operator-decision-table__cell operator-decision-table__cell--mode">
                            {row.mode}
                        </div>
                        <div class="operator-decision-table__cell">
                            {row.useWhen}
                        </div>
                        <div class="operator-decision-table__cell">
                            {row.returnSurface}
                        </div>
                        <div class="operator-decision-table__cell">
                            {row.output}
                        </div>
                    </>
                ))
            }
        </div>
    </section>

    <section class="page-grid-two page-grid-two-wide-right">
        <article class="page-module">
            <p class="eyebrow">Your cadence, not mine</p>
            <p>
                After the fork, the system is yours. You can keep my defaults,
                replace nearly every implementation detail, or selectively
                inherit ideas through Parley. You do not need to treat any of
                that as mandatory. The seed includes maintenance patterns like
                weekly version checks and expertise cleanup sweeps, but the real
                objective is to help you and your AI arrive at a cadence that
                feels rigorous and sustainable for you.
            </p>
        </article>
        <aside class="page-module content-aside service-capsules">
            <p class="eyebrow">Substrate services</p>
            <div class="operator-service-groups">
                {
                    serviceGroups.map((group) => (
                        <div class="operator-service-groups__item">
                            <p class="operator-service-groups__title">
                                {group.title}
                            </p>
                            <div class="service-list-grid service-list-grid--stacked">
                                {group.items.map((item) => (
                                    <div class="service-list-grid__item">
                                        {item}
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))
                }
            </div>
        </aside>
    </section>
</div>
