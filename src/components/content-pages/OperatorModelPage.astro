---
import ContentPageHero from './ContentPageHero.astro';

const surfaces = [
    {
        name: 'Pi session',
        use: 'Main place for shaping work, editing, debugging, and issuing commands.',
        when: 'Use when the task is still changing or you need direct control.',
    },
    {
        name: 'Hub web',
        use: 'Browser interface for visibility, review, state, and lighter interaction loops.',
        when: 'Use when you want a calmer operational surface than the terminal.',
    },
    {
        name: 'Dispatch',
        use: 'Async execution path for bounded background work.',
        when: 'Use when the task can run unattended and return later.',
    },
    {
        name: 'ntfy',
        use: 'Push notifications for completed work, blockers, and prompts for attention.',
        when: 'Use when you do not want to babysit a terminal or browser tab.',
    },
];

const flowRows = [
    [
        'Shape',
        'Pi session or Hub',
        'Clarify task, context, constraints, and desired output.',
    ],
    ['Launch', 'Pi session or Hub', 'Run directly or dispatch as async work.'],
    [
        'Execute',
        'Dispatch worker / tools',
        'Work happens against repos, files, services, or APIs.',
    ],
    [
        'Return',
        'Hub / PR / artifact / intercom',
        'Results come back through an explicit review surface.',
    ],
    [
        'Notify',
        'ntfy',
        'You get pulled back in only when something needs review or input.',
    ],
    [
        'Keep',
        'Tasks / Postgres / search',
        'Useful state stays durable instead of dissolving into chat history.',
    ],
];

const rules = [
    'Stay in Pi when the work is still being shaped.',
    'Dispatch only work that can return cleanly through review.',
    'Use Hub when you want visibility across sessions and jobs.',
    'Expect ntfy to pull you back when the system needs you.',
    'Treat durable state as part of the product, not as logging overhead.',
];
---

<div class="grid gap-10 md:gap-12">
    <ContentPageHero
        eyebrow="System / Operator model"
        title="How you interact with GalexC"
        lede="The operator model is not abstract. It is the set of surfaces you actually use: Pi sessions for direct work, Hub for browser-based visibility and review, dispatch for async jobs, and ntfy for getting pulled back in when the system needs attention."
    />

    <section class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6">
        <div class="grid gap-2.5 max-w-[44rem]">
            <p class="eyebrow">Interaction surfaces</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                Four surfaces you actually use
            </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
            {
                surfaces.map((surface) => (
                    <article class="grid gap-2 rounded-[1.2rem] border border-[rgba(120,113,108,0.14)] bg-[rgba(255,252,247,0.44)] p-5">
                        <h3 class="m-0 font-[Cormorant_Garamond,serif] text-[1.75rem] leading-[1.02] text-[#2b241d]">
                            {surface.name}
                        </h3>
                        <p class="m-0 text-[#4f4438] leading-relaxed">
                            {surface.use}
                        </p>
                        <p class="m-0 text-[#5b4f43] leading-relaxed">
                            <strong>Use when:</strong> {surface.when}
                        </p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6">
        <div class="grid gap-2.5 max-w-[44rem]">
            <p class="eyebrow">Interaction flow</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                The normal operating loop
            </h2>
        </div>
        <div
            class="overflow-x-auto rounded-[1.2rem] border border-[rgba(120,113,108,0.14)] bg-[rgba(255,252,247,0.42)] p-4 md:p-5"
        >
            <pre
                class="m-0 whitespace-pre-wrap font-[IBM_Plex_Mono,monospace] text-[0.72rem] leading-[1.7] text-[#4f4438] md:text-[0.78rem]">Pi / Hub
   │
   ├─ shape the work
   ├─ run directly or dispatch
   ▼
dispatch worker / tools
   │
   ├─ execute bounded work
   ├─ write state
   └─ generate artifact / PR / report
   ▼
Hub / intercom / review surface
   │
   ├─ operator reviews
   ├─ operator approves or revises
   └─ ntfy pulls operator back in when needed</pre>
        </div>
        <div
            class="grid grid-cols-[120px_180px_minmax(0,1fr)] gap-0 border-t border-l border-[rgba(120,113,108,0.12)] max-md:grid-cols-1"
        >
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                Step
            </div>
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                Primary surface
            </div>
            <div
                class="hidden md:block border-r border-b border-[rgba(120,113,108,0.12)] bg-[rgba(248,243,236,0.62)] px-4 py-3 font-[IBM_Plex_Mono,monospace] text-[0.68rem] uppercase tracking-[0.12em] text-[#6f6255]"
            >
                What happens
            </div>
            {
                flowRows.map(([step, surface, action]) => (
                    <>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#2b241d]">
                            {step}
                        </div>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#5b4f43]">
                            {surface}
                        </div>
                        <div class="border-r border-b border-[rgba(120,113,108,0.12)] px-4 py-3 text-[#5b4f43]">
                            {action}
                        </div>
                    </>
                ))
            }
        </div>
    </section>

    <section
        class="grid gap-5 border-t border-t-[rgba(120,113,108,0.14)] pt-6 max-w-[52rem]"
    >
        <div class="grid gap-2.5">
            <p class="eyebrow">Operating rules</p>
            <h2
                class="m-0 font-[Cormorant_Garamond,serif] text-[clamp(1.9rem,3vw,2.55rem)] leading-[0.98] text-[#2b241d]"
            >
                How the operator model stays sane
            </h2>
        </div>
        <ul class="m-0 grid list-none gap-3 p-0">
            {
                rules.map((rule) => (
                    <li class="border-t border-t-[rgba(120,113,108,0.12)] pt-3 text-[#4f4438] leading-relaxed">
                        {rule}
                    </li>
                ))
            }
        </ul>
    </section>
</div>
