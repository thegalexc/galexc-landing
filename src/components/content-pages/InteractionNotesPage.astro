---
import InteractionSeamStudy from '../graphics/InteractionSeamStudy.astro';
import ContentPageHero from './ContentPageHero.astro';

const lexicon = [
    ['Reveal', 'Information should feel uncovered rather than dropped in.'],
    [
        'Disclosure',
        'The operator should always understand what opened and why.',
    ],
    ['Settle', 'The last beat should be stillness, not momentum.'],
];

const rhythm = [
    ['Still', 'A closed surface should already feel composed.'],
    ['Invite', 'The trigger suggests depth without forcing it.'],
    ['Open', 'Motion stays near its origin and remains legible.'],
    ['Settle', 'Animation ends in a stable readable state.'],
    ['Hold', 'The interface stops speaking and hands control back.'],
];

const motionLedger = [
    ['Trigger', 'A single clear control should begin the reveal.'],
    ['Motion origin', 'The panel should open close to where intent began.'],
    ['Duration', 'Long enough to read, short enough to avoid theatrics.'],
    ['Easing', 'Soften the arrival and remove any snap.'],
    [
        'Settle state',
        'The end state should look like it belonged there all along.',
    ],
    ['Close behavior', 'Reversibility should stay obvious and low-friction.'],
];

const specimens = [
    {
        tone: 'Do',
        body: 'Reveal downward from the trigger, keep the seam visible, and let the panel settle into the page.',
    },
    {
        tone: "Don't",
        body: 'Do not launch content from off-canvas, overshoot the target, or keep motion alive after the state is clear.',
    },
];
---

<div class="essay-page interaction-page">
    <ContentPageHero
        eyebrow="Principles / Interaction notes"
        title="A calmer interaction language."
        lede="GalexC should not move like a productivity app trying to prove it is alive. It should open, reveal, and settle with the confidence of a well-kept notebook. The clearest current example is the request-access reveal on the landing page."
    />

    <section class="page-grid-two interaction-glossary-grid glossary-open-grid">
        {
            lexicon.map(([title, body]) => (
                <article class="page-module glossary-open-entry interaction-glossary-card">
                    <p class="eyebrow">{title}</p>
                    <p>{body}</p>
                </article>
            ))
        }
    </section>

    <section class="page-module specimen-frame interaction-study">
        <p class="eyebrow">Request-access reveal</p>
        <InteractionSeamStudy />
    </section>

    <section
        class="page-grid-two page-grid-two-wide-right interaction-specimen-grid"
    >
        <article class="page-module interaction-ledger-card">
            <p class="eyebrow">Interaction ledger</p>
            <div class="interaction-ledger">
                {
                    motionLedger.map(([title, body]) => (
                        <div class="interaction-ledger__item">
                            <p class="interaction-ledger__title">{title}</p>
                            <p>{body}</p>
                        </div>
                    ))
                }
            </div>
        </article>
        <aside class="page-module content-aside interaction-do-dont">
            <p class="eyebrow">Do / don't</p>
            {
                specimens.map((item) => (
                    <div
                        class:list={[
                            'interaction-do-dont__item',
                            item.tone === 'Do' &&
                                'interaction-do-dont__item-good',
                        ]}
                    >
                        <p class="interaction-do-dont__tone">{item.tone}</p>
                        <p>{item.body}</p>
                    </div>
                ))
            }
        </aside>
    </section>

    <section class="page-module rhythm-strip-card rhythm-strip-open">
        <p class="eyebrow">Pacing</p>
        <div class="rhythm-line rhythm-line--annotated">
            {
                rhythm.map(([item, note]) => (
                    <div class="rhythm-line__item">
                        <span class="rhythm-line__dot" />
                        <p>{item}</p>
                        <span class="rhythm-line__note">{note}</span>
                    </div>
                ))
            }
        </div>
    </section>
</div>
