---
import InteractionSeamStudy from '../graphics/InteractionSeamStudy.astro';
import ContentPageHero from './ContentPageHero.astro';

const lexicon = [
    ['Reveal', 'Information should feel uncovered rather than dropped in.'],
    [
        'Disclosure',
        'The operator should always understand what opened and why.',
    ],
    ['Settle', 'The last beat should be stillness, not momentum.'],
];

const rhythm = ['Still', 'Invite', 'Open', 'Settle', 'Hold'];
---

<div class="essay-page interaction-page">
    <ContentPageHero
        eyebrow="Principles / Interaction notes"
        title="A calmer interaction language."
        lede="GalexC should not move like a productivity app trying to prove it is alive. It should open, reveal, and settle with the confidence of a well-kept notebook. The clearest current example is the request-access reveal on the landing page."
    >
        <div slot="artifact" class="page-module">
            <InteractionSeamStudy />
        </div>
    </ContentPageHero>

    <section class="page-grid-two interaction-glossary-grid glossary-open-grid">
        {
            lexicon.map(([title, body]) => (
                <article class="page-module glossary-open-entry interaction-glossary-card">
                    <p class="eyebrow">{title}</p>
                    <p>{body}</p>
                </article>
            ))
        }
    </section>

    <section class="page-module specimen-frame interaction-study">
        <p class="eyebrow">Request-access reveal</p>
        <InteractionSeamStudy />
    </section>

    <section class="page-module rhythm-strip-card rhythm-strip-open">
        <p class="eyebrow">Pacing</p>
        <div class="rhythm-line rhythm-line--editorial">
            {
                rhythm.map((item, index) => (
                    <div class="rhythm-line__item">
                        <span
                            class="rhythm-line__dot"
                            style={`--rhythm-delay:${index * 0.6}s;`}
                        />
                        <p>{item}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="essay-sections">
        <article class="essay-sections__item">
            <h2>Reveal is the primary verb</h2>
            <p>
                Information should feel uncovered rather than dropped onto the
                page. That is why the request-access interaction unfolds
                downward from its trigger instead of arriving from somewhere
                off-canvas. Motion stays near its origin, so state change
                remains legible.
            </p>
        </article>
        <article class="essay-sections__item">
            <h2>Disclosure keeps control visible</h2>
            <p>
                Nothing important should arrive as a surprise. The operator
                should understand what opened, why it opened, and how to close
                it again. Indicator rotation, visible seams, and reversible
                state changes do more for trust than flashy transitions ever
                will.
            </p>
        </article>
        <article class="essay-sections__item">
            <h2>The final beat is stillness</h2>
            <p>
                A confident interface does not fidget. After the reveal, the
                page should settle and hold. That pause is part of the product
                posture. It tells the operator that the system has finished
                speaking and handed control back.
            </p>
        </article>
    </section>
</div>
