---
import InteractionSeamStudy from '../graphics/InteractionSeamStudy.astro';
import ContentPageHero from './ContentPageHero.astro';

const lexicon = [
    ['Reveal', 'Information should feel uncovered rather than dropped in.'],
    [
        'Disclosure',
        'The operator should always understand what opened and why.',
    ],
    ['Settle', 'The last beat should be stillness, not momentum.'],
];

const rhythm = [
    ['Still', 'A closed surface should already feel composed.'],
    ['Invite', 'The trigger suggests depth without forcing it.'],
    ['Open', 'Motion stays near its origin and remains legible.'],
    ['Settle', 'Animation ends in a stable readable state.'],
    ['Hold', 'The interface stops speaking and hands control back.'],
];

const motionLedger = [
    ['Trigger', 'A single clear control should begin the reveal.'],
    ['Motion origin', 'The panel should open close to where intent began.'],
    ['Duration', 'Long enough to read, short enough to avoid theatrics.'],
    ['Easing', 'Soften the arrival and remove any snap.'],
    [
        'Settle state',
        'The end state should look like it belonged there all along.',
    ],
    ['Close behavior', 'Reversibility should stay obvious and low-friction.'],
];

const specimens = [
    {
        tone: 'Do',
        body: 'Reveal downward from the trigger, keep the seam visible, and let the panel settle into the page.',
    },
    {
        tone: "Don't",
        body: 'Do not launch content from off-canvas, overshoot the target, or keep motion alive after the state is clear.',
    },
];
---

<div class="grid gap-[2.4rem]">
    <ContentPageHero
        eyebrow="Principles / Interaction notes"
        title="A calmer interaction language."
        lede="GalexC should not move like a productivity app trying to prove it is alive. It should open, reveal, and settle with the confidence of a well-kept notebook. The clearest current example is the request-access reveal on the landing page."
    />

    <section
        class="grid gap-4 items-start md:grid-cols-[repeat(2,minmax(0,1fr))]"
    >
        {
            lexicon.map(([title, body]) => (
                <article
                    class="grid gap-[0.9rem] pt-[0.9rem]"
                    style="border-top: 1px solid rgba(120, 113, 108, 0.14);"
                >
                    <p class="eyebrow">{title}</p>
                    <p>{body}</p>
                </article>
            ))
        }
    </section>

    <section
        class="grid gap-[0.9rem] p-[1.15rem_1.2rem] rounded-[1.35rem_0.95rem_1.15rem_0.92rem]"
        style="border: 1px solid rgba(120, 113, 108, 0.14); background: linear-gradient(180deg, rgba(255,255,255,0.44), rgba(251,247,241,0.52)), repeating-linear-gradient(180deg, rgba(120,113,108,0.038) 0, rgba(120,113,108,0.038) 1px, transparent 1px, transparent 33px); box-shadow: 0 10px 28px rgba(43,36,29,0.04);"
    >
        <p class="eyebrow">Request-access reveal</p>
        <InteractionSeamStudy />
    </section>

    <section
        class="grid gap-4 items-start md:grid-cols-[minmax(0,0.9fr)_minmax(280px,0.7fr)]"
    >
        <article
            class="grid gap-[0.9rem] pt-[0.9rem]"
            style="border-top: 1px solid rgba(120, 113, 108, 0.14);"
        >
            <p class="eyebrow">Interaction ledger</p>
            <div class="grid gap-0">
                {
                    motionLedger.map(([title, body], i) => (
                        <div
                            class="grid gap-[0.35rem] py-[0.95rem]"
                            style={
                                i > 0
                                    ? 'border-top: 1px solid rgba(120, 113, 108, 0.12);'
                                    : undefined
                            }
                        >
                            <p
                                class="font-['IBM_Plex_Mono',monospace] text-[0.68rem] tracking-[0.12em] uppercase"
                                style="color: #6f6255;"
                            >
                                {title}
                            </p>
                            <p>{body}</p>
                        </div>
                    ))
                }
            </div>
        </article>
        <aside
            class="grid gap-[0.6rem] pl-[1.15rem]"
            style="border-left: 2px solid rgba(21, 74, 122, 0.18);"
        >
            <p class="eyebrow">Do / don't</p>
            {
                specimens.map((item) => (
                    <div
                        class="grid gap-[0.45rem] p-4 rounded-[1rem]"
                        style={`border: 1px solid rgba(120, 113, 108, 0.14); background: ${item.tone === 'Do' ? 'rgba(255, 255, 255, 0.6)' : 'rgba(248, 243, 236, 0.72)'}; ${item.tone === 'Do' ? 'border-color: rgba(21, 74, 122, 0.18);' : ''}`}
                    >
                        <p
                            class="font-['IBM_Plex_Mono',monospace] text-[0.68rem] tracking-[0.12em] uppercase"
                            style="color: #6f6255;"
                        >
                            {item.tone}
                        </p>
                        <p style="color: #5d5145; line-height: 1.6;">
                            {item.body}
                        </p>
                    </div>
                ))
            }
        </aside>
    </section>

    <section
        class="grid gap-[0.9rem] pt-[0.9rem]"
        style="border-top: 1px solid rgba(120, 113, 108, 0.14);"
    >
        <p class="eyebrow">Pacing</p>
        <div
            class="grid gap-[0.8rem]"
            style="grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));"
        >
            {
                rhythm.map(([item, note]) => (
                    <div class="grid gap-[0.45rem] justify-items-center content-start">
                        <span
                            class="w-[0.7rem] h-[0.7rem] rounded-full"
                            style="background: rgba(21, 74, 122, 0.2); box-shadow: 0 0 0 6px rgba(21, 74, 122, 0.06);"
                        />
                        <p
                            class="m-0 font-['IBM_Plex_Mono',monospace] text-[0.72rem] tracking-[0.12em] uppercase"
                            style="color: #6f6255;"
                        >
                            {item}
                        </p>
                        <span
                            class="text-[0.92rem] text-left md:text-center"
                            style="color: #5d5145; line-height: 1.6;"
                        >
                            {note}
                        </span>
                    </div>
                ))
            }
        </div>
    </section>
</div>
