---
interface Props {
    current?: string;
    title: string;
    intro?: string;
}

const { title, intro } = Astro.props;
---

<section class="contents-shell">
    <div class="contents-shell__header">
        <a class="contents-shell__back eyebrow" href="/">GalexC</a>
        <h1 class="contents-shell__title">{title}</h1>
        {intro && <p class="contents-shell__intro">{intro}</p>}
    </div>
    <slot />
</section>
