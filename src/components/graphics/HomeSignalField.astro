---
const traces = [
    {
        d: 'M24 136C112 98 182 96 248 126C314 156 372 206 446 208C520 210 584 154 664 130C744 106 830 116 912 154',
        tone: 'home-signal-field__trace--ink',
    },
    {
        d: 'M22 252C98 216 170 214 232 232C294 250 350 288 420 284C490 280 558 236 628 218C698 200 792 208 914 254',
        tone: 'home-signal-field__trace--blue',
    },
    {
        d: 'M34 330C116 292 190 286 262 302C334 318 392 360 466 364C540 368 612 332 694 308C776 284 846 286 918 318',
        tone: 'home-signal-field__trace--warm',
    },
] as const;

const nodes = [
    { label: 'Context', x: '12%', y: '23%', delay: '0s' },
    { label: 'Judgment', x: '42%', y: '50%', delay: '1.3s' },
    { label: 'Execution', x: '76%', y: '31%', delay: '2.4s' },
    { label: 'Memory', x: '68%', y: '72%', delay: '3.1s' },
] as const;
---

<div class="home-signal-field" aria-hidden="true" data-graphic-reveal>
    <div class="home-signal-field__wash"></div>
    <svg
        class="home-signal-field__svg"
        viewBox="0 0 936 396"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
    >
        <defs>
            <linearGradient
                id="homeSignalWarm"
                x1="54"
                y1="112"
                x2="874"
                y2="318"
                gradientUnits="userSpaceOnUse"
            >
                <stop stop-color="#B86F2B"></stop>
                <stop offset="0.48" stop-color="#1E5E95"></stop>
                <stop offset="1" stop-color="#D0A56B"></stop>
            </linearGradient>
            <radialGradient
                id="homeSignalPool"
                cx="0"
                cy="0"
                r="1"
                gradientUnits="userSpaceOnUse"
                gradientTransform="translate(466 208) rotate(90) scale(160 204)"
            >
                <stop stop-color="rgba(255,255,255,0.82)"></stop>
                <stop offset="1" stop-color="rgba(255,255,255,0)"></stop>
            </radialGradient>
        </defs>

        <rect
            x="330"
            y="106"
            width="268"
            height="188"
            rx="94"
            fill="url(#homeSignalPool)"></rect>

        {
            traces.map((trace, index) => (
                <path
                    d={trace.d}
                    class:list={['home-signal-field__trace', trace.tone]}
                    style={`--trace-delay:${index * 1.2}s;`}
                />
            ))
        }

        <circle class="home-signal-field__anchor" cx="466" cy="208" r="8"
        ></circle>
        <circle
            class="home-signal-field__anchor home-signal-field__anchor--soft"
            cx="466"
            cy="208"
            r="22"></circle>

        <circle r="5.5" fill="#1E5E95">
            <animateMotion
                dur="13s"
                begin="-4s"
                repeatCount="indefinite"
                path="M24 136C112 98 182 96 248 126C314 156 372 206 446 208C520 210 584 154 664 130C744 106 830 116 912 154"
            ></animateMotion>
        </circle>
        <circle r="4.5" fill="#C98B4B">
            <animateMotion
                dur="12.5s"
                begin="-8s"
                repeatCount="indefinite"
                path="M22 252C98 216 170 214 232 232C294 250 350 288 420 284C490 280 558 236 628 218C698 200 792 208 914 254"
            ></animateMotion>
        </circle>
        <circle r="4.2" fill="#8E5525">
            <animateMotion
                dur="14.5s"
                begin="-2s"
                repeatCount="indefinite"
                path="M34 330C116 292 190 286 262 302C334 318 392 360 466 364C540 368 612 332 694 308C776 284 846 286 918 318"
            ></animateMotion>
        </circle>
    </svg>

    {
        nodes.map((node, index) => (
            <div
                class="home-signal-field__label"
                style={`left:${node.x};top:${node.y};--label-delay:${node.delay};--label-index:${index + 1};`}
            >
                <span class="home-signal-field__label-index">0{index + 1}</span>
                <span>{node.label}</span>
            </div>
        ))
    }

    <p class="home-signal-field__caption">
        Personal systems should gather signal, carry context, and settle into
        useful action.
    </p>
</div>

<style>
    .home-signal-field {
        position: relative;
        min-height: 23rem;
        overflow: hidden;
        border-radius: 2rem 5rem 2.4rem 2.1rem;
        border: 1px solid rgba(120, 113, 108, 0.15);
        background:
            linear-gradient(
                180deg,
                rgba(255, 252, 247, 0.88),
                rgba(244, 235, 222, 0.7)
            ),
            repeating-linear-gradient(
                180deg,
                rgba(120, 113, 108, 0.04) 0,
                rgba(120, 113, 108, 0.04) 1px,
                transparent 1px,
                transparent 40px
            );
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.82),
            0 28px 70px rgba(88, 64, 34, 0.11);
    }

    .home-signal-field__wash,
    .home-signal-field__svg {
        position: absolute;
        inset: 0;
    }

    .home-signal-field__wash {
        background:
            radial-gradient(
                circle at 18% 18%,
                rgba(194, 122, 55, 0.12),
                transparent 22%
            ),
            radial-gradient(
                circle at 82% 16%,
                rgba(21, 74, 122, 0.1),
                transparent 26%
            ),
            radial-gradient(
                circle at 54% 62%,
                rgba(255, 255, 255, 0.74),
                transparent 18%
            );
        pointer-events: none;
    }

    .home-signal-field__svg {
        width: 100%;
        height: 100%;
    }

    .home-signal-field__trace {
        fill: none;
        stroke: url(#homeSignalWarm);
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-dasharray: 1 10;
        animation: homeSignalTrace 18s linear infinite;
        animation-delay: var(--trace-delay);
        opacity: 0.72;
    }

    .home-signal-field__trace--ink {
        stroke-width: 2;
    }

    .home-signal-field__trace--blue {
        opacity: 0.56;
    }

    .home-signal-field__trace--warm {
        opacity: 0.44;
    }

    .home-signal-field__anchor {
        fill: #154a7a;
        animation: homeSignalAnchor 7s ease-in-out infinite;
    }

    .home-signal-field__anchor--soft {
        fill: rgba(21, 74, 122, 0.08);
    }

    .home-signal-field__label {
        position: absolute;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.42rem 0.78rem;
        border-radius: 999px;
        border: 1px solid rgba(120, 113, 108, 0.14);
        background: rgba(255, 252, 247, 0.8);
        box-shadow: 0 12px 24px rgba(88, 64, 34, 0.08);
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #6f6255;
        white-space: nowrap;
    }

    .home-signal-field__label-index {
        color: #154a7a;
    }

    .home-signal-field__caption {
        position: absolute;
        left: 1.25rem;
        right: 1.25rem;
        bottom: 1rem;
        margin: 0;
        max-width: 24rem;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #5b4f43;
    }

    @keyframes homeSignalTrace {
        to {
            stroke-dashoffset: -180;
        }
    }

    @keyframes homeSignalAnchor {
        0%,
        100% {
            transform: scale(1);
            opacity: 0.9;
        }
        50% {
            transform: scale(1.08);
            opacity: 1;
        }
    }

    @media (max-width: 767px) {
        .home-signal-field {
            min-height: 19rem;
            border-radius: 1.7rem 2.4rem 1.9rem 1.8rem;
        }

        .home-signal-field__label {
            font-size: 0.54rem;
            letter-spacing: 0.12em;
        }

        .home-signal-field__caption {
            max-width: 18rem;
            font-size: 0.86rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .home-signal-field__trace,
        .home-signal-field__anchor,
        animateMotion {
            animation: none;
        }
    }
</style>
