---
const stations = [
    {
        title: 'Session',
        detail: 'Live shaping and debugging close to the operator.',
        className: 'operator-orbit-diagram__station--session',
        style: 'left:50%;top:12%;--x:-50%;--y:0%;',
    },
    {
        title: 'Dispatch',
        detail: 'Bounded work leaves cleanly and returns with receipts.',
        className: 'operator-orbit-diagram__station--dispatch',
        style: 'left:14%;top:40%;--x:0%;--y:-50%;',
    },
    {
        title: 'Seed + services',
        detail: 'Continuity, memory, and maintenance pulse underneath.',
        className: 'operator-orbit-diagram__station--seed',
        style: 'left:84%;top:72%;--x:-100%;--y:-50%;',
    },
] as const;
---

<div class="operator-orbit-diagram" aria-hidden="true" data-graphic-reveal>
    <div
        class="operator-orbit-diagram__ring operator-orbit-diagram__ring--outer"
    >
    </div>
    <div
        class="operator-orbit-diagram__ring operator-orbit-diagram__ring--inner"
    >
    </div>
    <div
        class="operator-orbit-diagram__handoff operator-orbit-diagram__handoff--left"
    >
    </div>
    <div
        class="operator-orbit-diagram__handoff operator-orbit-diagram__handoff--right"
    >
    </div>
    <div
        class="operator-orbit-diagram__handoff operator-orbit-diagram__handoff--down"
    >
    </div>
    <div class="operator-orbit-diagram__center-badge">
        <span class="operator-orbit-diagram__center-code">Human</span>
        <span>Intent and standards stay still at the center.</span>
    </div>

    {
        stations.map((station) => (
            <article
                class:list={[
                    'operator-orbit-diagram__station',
                    station.className,
                ]}
                style={station.style}
            >
                <p class="operator-orbit-diagram__station-title">
                    {station.title}
                </p>
                <p class="operator-orbit-diagram__station-detail">
                    {station.detail}
                </p>
            </article>
        ))
    }
</div>

<style>
    .operator-orbit-diagram {
        position: relative;
        min-height: 26rem;
        overflow: hidden;
        border-radius: 2rem;
        border: 1px solid rgba(120, 113, 108, 0.14);
        background:
            radial-gradient(
                circle at 50% 52%,
                rgba(255, 255, 255, 0.82),
                rgba(255, 255, 255, 0) 18%
            ),
            radial-gradient(
                circle at 24% 22%,
                rgba(21, 74, 122, 0.08),
                transparent 24%
            ),
            radial-gradient(
                circle at 78% 26%,
                rgba(193, 122, 57, 0.08),
                transparent 24%
            ),
            linear-gradient(
                180deg,
                rgba(255, 252, 247, 0.86),
                rgba(244, 235, 222, 0.72)
            );
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
    }

    .operator-orbit-diagram__ring,
    .operator-orbit-diagram__handoff {
        position: absolute;
        inset: 50% auto auto 50%;
        transform: translate(-50%, -50%);
        border-radius: 999px;
        pointer-events: none;
    }

    .operator-orbit-diagram__ring--outer {
        width: 72%;
        height: 72%;
        border: 1px solid rgba(120, 113, 108, 0.16);
    }

    .operator-orbit-diagram__ring--inner {
        width: 42%;
        height: 42%;
        border: 1px dashed rgba(21, 74, 122, 0.22);
        animation: operatorOrbitSpin 26s linear infinite;
    }

    .operator-orbit-diagram__handoff {
        width: 34%;
        height: 1px;
        background: linear-gradient(
            90deg,
            rgba(120, 113, 108, 0),
            rgba(21, 74, 122, 0.35),
            rgba(120, 113, 108, 0)
        );
        opacity: 0.72;
    }

    .operator-orbit-diagram__handoff--left {
        width: 22%;
        left: 37%;
        top: 39%;
        transform: rotate(-14deg);
    }

    .operator-orbit-diagram__handoff--right {
        width: 22%;
        left: 63%;
        top: 40%;
        transform: rotate(18deg);
    }

    .operator-orbit-diagram__handoff--down {
        width: 18%;
        left: 50%;
        top: 64%;
        transform: translate(-50%, -50%) rotate(90deg);
    }

    .operator-orbit-diagram__station {
        position: absolute;
        width: min(10rem, calc(100% - 2rem));
        padding: 0.9rem 1rem;
        border-radius: 1.2rem;
        border: 1px solid rgba(120, 113, 108, 0.14);
        background: rgba(255, 252, 247, 0.8);
        box-shadow: 0 16px 32px rgba(88, 64, 34, 0.08);
        transform: translate(var(--x), var(--y));
    }

    .operator-orbit-diagram__station-title {
        margin: 0;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #154a7a;
    }

    .operator-orbit-diagram__station-detail {
        margin: 0.45rem 0 0;
        color: #5b4f43;
        line-height: 1.55;
        font-size: 0.9rem;
    }

    .operator-orbit-diagram__center-badge {
        position: absolute;
        left: 50%;
        top: 50%;
        display: grid;
        gap: 0.22rem;
        width: 9.5rem;
        padding: 0.7rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(120, 113, 108, 0.14);
        background: rgba(255, 250, 243, 0.92);
        text-align: center;
        color: #5b4f43;
        transform: translate(-50%, -50%);
        box-shadow: 0 12px 24px rgba(88, 64, 34, 0.08);
    }

    .operator-orbit-diagram__center-code {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #154a7a;
    }

    @keyframes operatorOrbitSpin {
        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }

    @media (max-width: 767px) {
        .operator-orbit-diagram {
            min-height: 29rem;
        }

        .operator-orbit-diagram__station {
            width: min(10.5rem, calc(100% - 2rem));
        }

        .operator-orbit-diagram__station-detail {
            font-size: 0.82rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .operator-orbit-diagram__ring--inner {
            animation: none;
        }
    }
</style>
