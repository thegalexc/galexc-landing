---
interface Props {
    issuedAt: string;
    formToken: string;
    siteKey?: string;
    previewMode?: boolean;
    status?: {
        tone: 'success' | 'error' | 'info';
        message: string;
    } | null;
}

const { issuedAt, formToken, siteKey, previewMode = false, status = null } = Astro.props;
---

<section id="waitlist" class="waitlist-form-shell p-6 md:p-8">
    <div class="flex flex-col gap-3">
        <h2 class="text-3xl text-stone-900">
            What are you most hoping to get out of a <em>personal</em> AI?
        </h2>
    </div>

    <div class="mt-5">
        {
            status && (
                <div class:list={['status-banner', status.tone]}>
                    {status.message}
                </div>
            )
        }
    </div>

    <form method="POST" action="/api/waitlist" class="waitlist-form">
        <input type="hidden" name="issued_at" value={issuedAt} />
        <input type="hidden" name="form_token" value={formToken} />
        <input type="hidden" name="source" value="landing" />

        <div>
            <input
                id="waitlist-name"
                class="waitlist-input"
                type="text"
                name="name"
                required
                maxlength="160"
                autocomplete="name"
                placeholder="Your name"
                aria-label="Name"
            />
        </div>

        <div>
            <input
                id="waitlist-email"
                class="waitlist-input"
                type="email"
                name="email"
                required
                maxlength="320"
                autocomplete="email"
                placeholder="you@example.com"
                aria-label="Email"
            />
        </div>

        <div class="waitlist-note-block">
            <p class="waitlist-note-prompt">
                Please share what you would like to get out of your <em>personal</em>
                AI. Anectodes about what is and is not working about your current
                setup are extremely informative as well. The more detail you care to
                provide, the better, as this helps steer GalexC and tailor to your
                needs.
            </p>
            <textarea
                id="waitlist-note"
                class="waitlist-textarea"
                name="note"
                required
                maxlength="5000"
                placeholder="Share as much detail as you would like."
                aria-label="What you would like to get out of your personal AI"
            ></textarea>
        </div>

        {
            previewMode && (
                <div class="status-banner info waitlist-dev-note">
                    Preview build only - submissions are disabled here.
                </div>
            )
        }

        <div class="sr-only" aria-hidden="true">
            <label>
                Company
                <input
                    type="text"
                    name="company"
                    tabindex="-1"
                    autocomplete="off"
                />
            </label>
        </div>

        {!previewMode && siteKey && (
            <>
                <div class="waitlist-turnstile" data-turnstile-host>
                    <div
                        class="cf-turnstile"
                        data-sitekey={siteKey}
                        data-theme="light"
                        data-size="flexible"
                        data-appearance="interaction-only"
                        data-callback="galexcTurnstileSuccess"
                        data-error-callback="galexcTurnstileError"
                        data-expired-callback="galexcTurnstileExpired"
                        data-timeout-callback="galexcTurnstileTimeout"
                        data-before-interactive-callback="galexcTurnstileBeforeInteractive"
                        data-after-interactive-callback="galexcTurnstileAfterInteractive"
                    />
                </div>
                <p class="waitlist-turnstile-status" data-turnstile-status hidden></p>
            </>
        )}

        <div class="waitlist-actions">
            <button
                class="waitlist-button"
                type="submit"
                disabled={previewMode || !siteKey}
                data-waitlist-submit
                >Request access <span aria-hidden="true">→</span></button
            >
        </div>
    </form>

    {
        !previewMode && !siteKey && (
            <div class="status-banner info waitlist-dev-note">
                Turnstile is not configured yet. The form will stay disabled
                until the site key and secret are set.
            </div>
        )
    }

    {!previewMode && siteKey && (
        <>
            <script is:inline>
                (() => {
                    const submitButton = document.querySelector('[data-waitlist-submit]');
                    const turnstileHost = document.querySelector('[data-turnstile-host]');
                    const statusNode = document.querySelector('[data-turnstile-status]');

                    if (!(submitButton instanceof HTMLButtonElement)) {
                        return;
                    }

                    const setStatus = (message = '') => {
                        if (!(statusNode instanceof HTMLElement)) {
                            return;
                        }
                        statusNode.textContent = message;
                        statusNode.hidden = !message;
                    };

                    const setReady = (ready) => {
                        submitButton.disabled = !ready;
                    };

                    const setInteractive = (interactive) => {
                        if (!(turnstileHost instanceof HTMLElement)) {
                            return;
                        }
                        turnstileHost.classList.toggle('is-visible', interactive);
                    };

                    setReady(false);
                    setStatus('');
                    setInteractive(false);

                    window.galexcTurnstileSuccess = () => {
                        setReady(true);
                        setStatus('');
                        setInteractive(false);
                    };

                    window.galexcTurnstileError = () => {
                        setReady(false);
                        setStatus('Verification could not load. Please try again.');
                    };

                    window.galexcTurnstileExpired = () => {
                        setReady(false);
                        setStatus('Verification expired. Please try again.');
                    };

                    window.galexcTurnstileTimeout = () => {
                        setReady(false);
                        setStatus('Verification timed out. Please try again.');
                        setInteractive(true);
                    };

                    window.galexcTurnstileBeforeInteractive = () => {
                        setInteractive(true);
                        setStatus('');
                    };

                    window.galexcTurnstileAfterInteractive = () => {
                        setInteractive(false);
                    };
                })();
            </script>
            <script
                is:inline
                src="https://challenges.cloudflare.com/turnstile/v0/api.js"
                async
                defer
            />
        </>
    )}
</section>
