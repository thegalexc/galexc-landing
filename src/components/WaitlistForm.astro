---
interface Props {
    issuedAt: string;
    formToken: string;
    siteKey?: string;
    status?: {
        tone: "success" | "error" | "info";
        message: string;
    } | null;
}

const { issuedAt, formToken, siteKey, status = null } = Astro.props;
---

<section id="waitlist" class="waitlist-form-shell p-6 md:p-8">
    <div class="flex flex-col gap-3">
        <h2 class="text-3xl text-stone-900">
            What are you most hoping to get out of a <em>personal</em> AI?
        </h2>
    </div>

    <div class="mt-5">
        {
            status && (
                <div class:list={["status-banner", status.tone]}>
                    {status.message}
                </div>
            )
        }
    </div>

    <form method="POST" action="/api/waitlist" class="waitlist-form">
        <input type="hidden" name="issued_at" value={issuedAt} />
        <input type="hidden" name="form_token" value={formToken} />
        <input type="hidden" name="source" value="landing" />

        <label class="sr-only" for="waitlist-email">Email</label>
        <input
            id="waitlist-email"
            class="waitlist-input"
            type="email"
            name="email"
            required
            maxlength="320"
            autocomplete="email"
            placeholder="you@example.com"
        />

        <div class="waitlist-note-block">
            <label class="waitlist-field-label" for="waitlist-note">
                In a sentence or two
            </label>
            <textarea
                id="waitlist-note"
                class="waitlist-textarea"
                name="note"
                maxlength="800"
                placeholder="A sentence or two."></textarea>
        </div>

        <div class="sr-only" aria-hidden="true">
            <label>
                Company
                <input
                    type="text"
                    name="company"
                    tabindex="-1"
                    autocomplete="organization"
                />
            </label>
        </div>

        {siteKey && (
            <div class="waitlist-turnstile overflow-x-auto">
                <div class="cf-turnstile" data-sitekey={siteKey} />
            </div>
        )}

        <div class="waitlist-actions">
            <button class="waitlist-button" type="submit" disabled={!siteKey}
                >Request access <span aria-hidden="true">→</span></button
            >
        </div>
    </form>

    {!siteKey && (
        <div class="status-banner info waitlist-dev-note">
            Turnstile is not configured yet. The form will stay disabled until the site key and secret are set.
        </div>
    )}

    {
        siteKey && (
            <script
                is:inline
                src="https://challenges.cloudflare.com/turnstile/v0/api.js"
                async
                defer
            />
        )
    }
</section>
