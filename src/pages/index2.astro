---
import { env } from 'cloudflare:workers';
import DisclosureScript from '../components/DisclosureScript.astro';
import LandingHero from '../components/LandingHero.astro';
import StudyLinks from '../components/StudyLinks.astro';
import WaitlistReveal from '../components/WaitlistReveal.astro';
import Layout from '../layouts/Layout.astro';
import { createFormToken } from '../lib/form-token';
import { navGroups } from '../lib/site-content';
import { isPreviewMode } from '../lib/preview-mode';
import { getWaitlistStatus } from '../lib/waitlist-state';

const previewMode = isPreviewMode();
const issuedAt = Date.now().toString();
const formToken = await createFormToken(issuedAt, 'waitlist');
const siteKey = previewMode ? undefined : env.TURNSTILE_SITE_KEY;
const waitlistStatus = getWaitlistStatus(Astro.url.searchParams.get('waitlist'));
---

<Layout title="GalexC - Study 02" description="TOC Drop navigation study for GalexC." noindex>
    <div class="editorial-shell page-stack px-4 py-8 md:px-6 md:py-12">
        <StudyLinks current="index2" />

        <section class="page-stage panel toc-shell">
            <LandingHero
                eyebrow="Study 02 · TOC drop"
                title="Open the table of contents."
                intro="A single trigger unfolds the site's structure like a folio or magazine index, letting the landing page stay minimal until the visitor asks for more."
            />

            <div class="toc-drop" data-reveal data-open="true">
                <button
                    class="toc-drop__trigger"
                    type="button"
                    aria-expanded="true"
                    aria-controls="toc-panel"
                    data-reveal-trigger
                >
                    <span>Contents</span>
                </button>
                <div id="toc-panel" class="toc-drop__panel" data-reveal-panel>
                    <div class="toc-drop__grid">
                        {
                            navGroups.map((group) => (
                                <section class="toc-drop__group">
                                    <p class="eyebrow">{group.title}</p>
                                    {
                                        group.items.map((item, itemIndex) => (
                                            <a class="toc-row" href={`/${item.slug}`}>
                                                <span class="toc-row__label">{item.label}</span>
                                                <span class="toc-row__leader" aria-hidden="true"></span>
                                                <span class="toc-row__index">
                                                    {group.title.slice(0, 1)}{itemIndex + 1}
                                                </span>
                                            </a>
                                        ))
                                    }
                                </section>
                            ))
                        }
                    </div>
                </div>
            </div>

            <WaitlistReveal
                issuedAt={issuedAt}
                formToken={formToken}
                siteKey={siteKey}
                status={waitlistStatus}
                previewMode={previewMode}
                title="Request access"
                open={Boolean(waitlistStatus)}
            />
        </section>
    </div>

    <DisclosureScript />
</Layout>
