---
import ContentsPageShell from '../components/ContentsPageShell.astro';
import Layout from '../layouts/Layout.astro';
import { navGroups, contentsVariants } from '../lib/site-content';

const variant = contentsVariants[0];
---

<Layout title="GalexC - Contents" description="GalexC contents ledger." noindex>
    <div class="editorial-shell px-4 py-8 md:px-6 md:py-12">
        <ContentsPageShell
            current={variant.slug}
            title={variant.title}
            intro={variant.intro}
        >
            <div class="contents-ledger">
                {
                    navGroups.map((group) => (
                        <section class="contents-ledger__group">
                            <p class="eyebrow">{group.title}</p>
                            {
                                group.items.map((item, index) => (
                                    <a class="contents-ledger__row" href={`/${item.slug}`}>
                                        <span class="contents-ledger__label">{item.label}</span>
                                        <span class="contents-ledger__leader" aria-hidden="true"></span>
                                        <span class="contents-ledger__meta">
                                            {group.title.slice(0, 1)}0{index + 1}
                                        </span>
                                    </a>
                                ))
                            }
                        </section>
                    ))
                }
            </div>
        </ContentsPageShell>
    </div>
</Layout>
