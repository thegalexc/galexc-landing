---
import { env } from 'cloudflare:workers';
import WaitlistForm from '../components/WaitlistForm.astro';
import Layout from '../layouts/Layout.astro';
import { createFormToken } from '../lib/form-token';

const issuedAt = Date.now().toString();
const formToken = await createFormToken(issuedAt, 'waitlist');
const siteKey = env.TURNSTILE_SITE_KEY;
const waitlistState = Astro.url.searchParams.get('waitlist');

const stateMap = {
  success: {
    tone: 'success',
    message: 'You are on the list. Thanks for the signal.',
  },
  invalid: {
    tone: 'error',
    message: 'That submission could not be accepted. Please check the form and try again.',
  },
  rate_limited: {
    tone: 'error',
    message: 'That form has seen too many recent attempts. Please wait a bit and try again.',
  },
  unavailable: {
    tone: 'error',
    message: 'The waitlist is not ready yet. I still need a few deployment settings to finish the live flow.',
  },
  blocked: {
    tone: 'error',
    message: 'That submission looked automated, so it was not accepted.',
  },
} as const;

const waitlistStatus = waitlistState && waitlistState in stateMap ? stateMap[waitlistState as keyof typeof stateMap] : null;
---

<Layout
  title="GalexC"
  description="GalexC is in private formation. Join the waitlist if you want early access."
  noindex
>
  <div class="editorial-shell px-4 py-8 md:px-6 md:py-12">
    <section class="mx-auto max-w-4xl panel rounded-[2rem] p-6 md:p-10">
      <div class="mb-8 flex flex-col gap-4">
        <p class="eyebrow">GalexC / private waitlist</p>
        <h1 class="max-w-3xl text-5xl leading-[0.96] text-stone-950 md:text-7xl">
          GalexC is not public yet.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-stone-700 md:text-xl">
          For now, this page is just a waitlist. If you want early access, tell me what you are hoping it can do for you.
        </p>
      </div>

      <WaitlistForm issuedAt={issuedAt} formToken={formToken} siteKey={siteKey} status={waitlistStatus} />
    </section>
  </div>
</Layout>
