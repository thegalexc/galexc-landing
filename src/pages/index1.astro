---
import { env } from 'cloudflare:workers';
import DisclosureScript from '../components/DisclosureScript.astro';
import LandingHero from '../components/LandingHero.astro';
import StudyLinks from '../components/StudyLinks.astro';
import WaitlistReveal from '../components/WaitlistReveal.astro';
import Layout from '../layouts/Layout.astro';
import { createFormToken } from '../lib/form-token';
import { navGroups } from '../lib/site-content';
import { isPreviewMode } from '../lib/preview-mode';
import { getWaitlistStatus } from '../lib/waitlist-state';

const previewMode = isPreviewMode();
const issuedAt = Date.now().toString();
const formToken = await createFormToken(issuedAt, 'waitlist');
const siteKey = previewMode ? undefined : env.TURNSTILE_SITE_KEY;
const waitlistStatus = getWaitlistStatus(Astro.url.searchParams.get('waitlist'));
---

<Layout title="GalexC - Study 01" description="Folio Spine navigation study for GalexC." noindex>
    <div class="editorial-shell page-stack page-stack--folio px-4 py-8 md:px-6 md:py-12">
        <StudyLinks current="index1" />

        <section class="folio-shell panel">
            <nav class="folio-rail" aria-label="Section navigation">
                {
                    navGroups.map((group) => (
                        <a href={`/${group.items[0]?.slug ?? ''}`}>{group.title}</a>
                    ))
                }
            </nav>

            <div class="folio-body">
                <LandingHero
                    eyebrow="Study 01 · Folio spine"
                    title="Navigation as a left-margin artifact."
                    intro="This version treats the site like a bound volume. The page stays quiet in the center while the left rail behaves like a stack of chapter spines."
                />

                <div class="folio-groups">
                    {
                        navGroups.map((group) => (
                            <section class="folio-group">
                                <div>
                                    <p class="eyebrow">{group.title}</p>
                                    <p class="folio-group__intro">{group.intro}</p>
                                </div>
                                <div class="folio-group__links">
                                    {
                                        group.items.map((item) => (
                                            <a class="folio-group__link" href={`/${item.slug}`}>
                                                <span>{item.label}</span>
                                                <span>{item.blurb}</span>
                                            </a>
                                        ))
                                    }
                                </div>
                            </section>
                        ))
                    }
                </div>

                <WaitlistReveal
                    issuedAt={issuedAt}
                    formToken={formToken}
                    siteKey={siteKey}
                    status={waitlistStatus}
                    previewMode={previewMode}
                    title="Open the access card"
                    open={Boolean(waitlistStatus)}
                />
            </div>
        </section>
    </div>

    <DisclosureScript />
</Layout>
