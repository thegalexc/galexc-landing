---
import ContentsPageShell from '../components/ContentsPageShell.astro';
import DisclosureScript from '../components/DisclosureScript.astro';
import Layout from '../layouts/Layout.astro';
import { navGroups, contentsVariants } from '../lib/site-content';

const variant = contentsVariants[3];
---

<Layout title="GalexC - Contents Map" description="GalexC contents disclosure map." noindex>
    <div class="editorial-shell px-4 py-8 md:px-6 md:py-12">
        <ContentsPageShell
            current={variant.slug}
            title={variant.title}
            intro={variant.intro}
        >
            <div class="contents-map">
                {
                    navGroups.map((group, index) => (
                        <section
                            class="contents-map__group"
                            data-reveal
                            data-open={index === 0 ? 'true' : 'false'}
                        >
                            <button
                                class="contents-map__trigger"
                                type="button"
                                aria-expanded={index === 0 ? 'true' : 'false'}
                                aria-controls={`contents-map-${group.id}`}
                                data-reveal-trigger
                            >
                                <span class="contents-map__title">{group.title}</span>
                                <span class="contents-map__intro">{group.intro}</span>
                            </button>
                            <div
                                id={`contents-map-${group.id}`}
                                class="contents-map__panel"
                                data-reveal-panel
                                hidden={index !== 0}
                            >
                                <div class="contents-map__links">
                                    {
                                        group.items.map((item) => (
                                            <a class="contents-map__link" href={`/${item.slug}`}>
                                                <span class="contents-map__label">{item.label}</span>
                                                <span class="contents-map__blurb">{item.blurb}</span>
                                            </a>
                                        ))
                                    }
                                </div>
                            </div>
                        </section>
                    ))
                }
            </div>
        </ContentsPageShell>
    </div>

    <DisclosureScript />
</Layout>
