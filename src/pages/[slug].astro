---
import ArchitectureOverviewPage from '../components/content-pages/ArchitectureOverviewPage.astro';
import ComparisonLandscapePage from '../components/content-pages/ComparisonLandscapePage.astro';
import ContentPageFooterNav from '../components/content-pages/ContentPageFooterNav.astro';
import DesignPhilosophyPage from '../components/content-pages/DesignPhilosophyPage.astro';
import InteractionNotesPage from '../components/content-pages/InteractionNotesPage.astro';
import InspirationPage from '../components/content-pages/InspirationPage.astro';
import OperatorModelPage from '../components/content-pages/OperatorModelPage.astro';
import WhatIsGalexCPage from '../components/content-pages/WhatIsGalexCPage.astro';
import Layout from '../layouts/Layout.astro';
import {
    contentPages,
    getAdjacentContent,
    getNavCode,
    navGroups,
    type NavItem,
} from '../lib/site-content';

export const prerender = true;

export function getStaticPaths() {
    return contentPages.map((page) => ({
        params: { slug: page.slug },
        props: { page },
    }));
}

const { page } = Astro.props as { page: NavItem };
const adjacent = getAdjacentContent(page.slug);

const pageComponents = {
    'what-is-galexc': WhatIsGalexCPage,
    inspiration: InspirationPage,
    'architecture-overview': ArchitectureOverviewPage,
    'operator-model': OperatorModelPage,
    'design-philosophy': DesignPhilosophyPage,
    'interaction-notes': InteractionNotesPage,
    'comparison-landscape': ComparisonLandscapePage,
} as const;

const PageBody = pageComponents[page.slug as keyof typeof pageComponents];
---

<Layout title={`GalexC - ${page.label}`} description={page.blurb} noindex>
    <div class="editorial-shell page-stack px-4 py-8 md:px-6 md:py-12">
        <div class="content-page">
            <aside class="content-page__nav" aria-label="Contents ledger">
                <p class="content-page__back eyebrow">
                    <a href="/">GalexC</a>
                    <span aria-hidden="true"> / </span>
                    <a href="/contents">Contents</a>
                </p>
                {
                    navGroups.map((group) => (
                        <div class="content-page__nav-group">
                            <p>{group.title}</p>
                            {group.items.map((item, index) => (
                                <a
                                    class:list={[
                                        'content-page__nav-link',
                                        item.slug === page.slug && 'active',
                                    ]}
                                    href={`/${item.slug}`}
                                >
                                    <span class="content-page__nav-code">
                                        {getNavCode(group.title, index)}
                                    </span>
                                    <span class="content-page__nav-label">
                                        {item.label}
                                    </span>
                                </a>
                            ))}
                        </div>
                    ))
                }
            </aside>

            <article class="content-page__main">
                <PageBody />

                <ContentPageFooterNav
                    previous={adjacent.previous}
                    next={adjacent.next}
                />
            </article>
        </div>
    </div>
</Layout>
