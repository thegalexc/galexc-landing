---
import Layout from '../layouts/Layout.astro';
import { contentPages, getAdjacentContent, navGroups, type NavItem } from '../lib/site-content';

export const prerender = true;

export function getStaticPaths() {
    return contentPages.map((page) => ({
        params: { slug: page.slug },
        props: { page },
    }));
}

const { page } = Astro.props as { page: NavItem };
const adjacent = getAdjacentContent(page.slug);
---

<Layout title={`GalexC - ${page.label}`} description={page.blurb} noindex>
    <div class="editorial-shell page-stack px-4 py-8 md:px-6 md:py-12">
        <article class="content-page panel">
            <header class="content-page__header">
                <p class="eyebrow">{page.eyebrow}</p>
                <h1>{page.label}</h1>
                <p class="content-page__summary">{page.summary}</p>
            </header>

            <div class="content-page__body">
                <aside class="content-page__index">
                    <p class="eyebrow">Index</p>
                    {
                        navGroups.map((group) => (
                            <div class="content-page__index-group">
                                <p>{group.title}</p>
                                {
                                    group.items.map((item) => (
                                        <a
                                            class:list={[
                                                'content-page__index-link',
                                                item.slug === page.slug && 'active',
                                            ]}
                                            href={`/${item.slug}`}
                                        >
                                            {item.label}
                                        </a>
                                    ))
                                }
                            </div>
                        ))
                    }
                    <a class="content-page__home-link" href="/contents">Back to contents</a>
                    <a class="content-page__home-link" href="/">Return to landing</a>
                </aside>

                <div class="content-page__sections">
                    {
                        page.sections.map((section) => (
                            <section class="content-page__section">
                                <h2>{section.title}</h2>
                                <p>{section.body}</p>
                            </section>
                        ))
                    }
                </div>
            </div>

            <footer class="content-page__footer">
                {adjacent.previous && (
                    <a class="content-page__pager" href={`/${adjacent.previous.slug}`}>
                        <span class="eyebrow">Previous</span>
                        <span>{adjacent.previous.label}</span>
                    </a>
                )}
                {adjacent.next && (
                    <a class="content-page__pager" href={`/${adjacent.next.slug}`}>
                        <span class="eyebrow">Next</span>
                        <span>{adjacent.next.label}</span>
                    </a>
                )}
            </footer>
        </article>
    </div>
</Layout>
