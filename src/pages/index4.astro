---
import { env } from 'cloudflare:workers';
import DisclosureScript from '../components/DisclosureScript.astro';
import LandingHero from '../components/LandingHero.astro';
import StudyLinks from '../components/StudyLinks.astro';
import WaitlistReveal from '../components/WaitlistReveal.astro';
import Layout from '../layouts/Layout.astro';
import { createFormToken } from '../lib/form-token';
import { contentPages } from '../lib/site-content';
import { isPreviewMode } from '../lib/preview-mode';
import { getWaitlistStatus } from '../lib/waitlist-state';

const previewMode = isPreviewMode();
const issuedAt = Date.now().toString();
const formToken = await createFormToken(issuedAt, 'waitlist');
const siteKey = previewMode ? undefined : env.TURNSTILE_SITE_KEY;
const waitlistStatus = getWaitlistStatus(Astro.url.searchParams.get('waitlist'));
const chapterLinks = contentPages.map((item, index) => ({
    title: item.label,
    href: `/${item.slug}`,
    index: `0${index + 1}`.slice(-2),
    eyebrow: item.eyebrow,
}));
---

<Layout title="GalexC - Study 04" description="Chapter Bar navigation study for GalexC." noindex>
    <div class="editorial-shell page-stack px-4 py-8 md:px-6 md:py-12">
        <StudyLinks current="index4" />

        <section class="page-stage panel chapter-shell">
            <LandingHero
                eyebrow="Study 04 · Chapter bar"
                title="The custom top-strip experiment."
                intro="This is the closest thing to a horizontal navbar, but it is treated like a chapter index rather than a product menu. The strip can stretch to the full route set and still feel custom if the typography and spacing stay restrained."
            />

            <nav class="chapter-bar" aria-label="Chapter index">
                {
                    chapterLinks.map((link) => (
                        <a class="chapter-bar__link" href={link.href}>
                            <span class="chapter-bar__dot" aria-hidden="true"></span>
                            <span>{link.title}</span>
                            <span class="chapter-bar__count">{link.index}</span>
                            <span class="chapter-bar__eyebrow">{link.eyebrow}</span>
                        </a>
                    ))
                }
            </nav>

            <div class="chapter-shell__detail">
                <p class="eyebrow">Why it exists</p>
                <p>
                    One of the five studies had to prove whether a top-oriented navigation
                    could work without reading like SaaS chrome. This version exposes every
                    route in a scrollable chapter strip, using muted dots, mono indexes, and
                    taxonomy labels instead of product-menu styling.
                </p>
            </div>

            <WaitlistReveal
                issuedAt={issuedAt}
                formToken={formToken}
                siteKey={siteKey}
                status={waitlistStatus}
                previewMode={previewMode}
                title="Request access"
                open={Boolean(waitlistStatus)}
            />
        </section>
    </div>

    <DisclosureScript />
</Layout>
