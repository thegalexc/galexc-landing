---
import Layout from '../layouts/Layout.astro';
import { listUsers, listWaitlistEntries, getWaitlistStats } from '../lib/db';
import type { PortalUser } from '../types/portal';
import type { WaitlistEntryRecord } from '../lib/db';

const adminUser = Astro.locals.adminUser;
let users: PortalUser[] = [];
let entries: WaitlistEntryRecord[] = [];
let stats = { total: 0, today: 0 };
let loadError: string | null = null;

try {
    [users, entries, stats] = await Promise.all([
        listUsers(),
        listWaitlistEntries(),
        getWaitlistStats(),
    ]);
} catch (error) {
    loadError =
        error instanceof Error ? error.message : 'Failed to load admin data.';
}

const adminCount = users.filter((user) => user.roles.includes('admin')).length;
---

<Layout
    title="GalexC Admin"
    description="Private admin dashboard for GalexC users and waitlist review."
    noindex
>
    <div class="editorial-shell px-4 py-8 md:px-6 md:py-10">
        <header class="rounded-[1.75rem] p-6 md:p-8">
            <p class="eyebrow">Private admin surface</p>
            <div
                class="mt-3 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between"
            >
                <div>
                    <h1 class="text-5xl text-stone-950 md:text-6xl">
                        Users and submissions
                    </h1>
                    <p class="mt-3 text-lg leading-8 text-stone-700">
                        Signed in as <span class="font-medium text-stone-900"
                            >{adminUser?.email}</span
                        >.
                    </p>
                </div>
                <div
                    class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end"
                >
                    <div class="rounded-[1.25rem] bg-white/55 px-5 py-4">
                        <div class="metric-value text-[2.4rem]">
                            {users.length}
                        </div>
                        <div class="metric-label">Users</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-white/55 px-5 py-4">
                        <div class="metric-value text-[2.4rem]">
                            {stats.total}
                        </div>
                        <div class="metric-label">Submissions</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-white/55 px-5 py-4">
                        <div class="metric-value text-[2.4rem]">
                            {stats.today}
                        </div>
                        <div class="metric-label">Today</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-white/55 px-5 py-4">
                        <div class="metric-value text-[2.4rem]">
                            {adminCount}
                        </div>
                        <div class="metric-label">Admins</div>
                    </div>
                </div>
            </div>
            <div class="mt-5 flex justify-end">
                <form action="/api/session/logout" method="POST">
                    <button
                        type="submit"
                        class="secondary-button cursor-pointer"
                    >
                        Logout
                    </button>
                </form>
            </div>
        </header>

        {
            loadError ? (
                <div class="status-banner error mt-6">{loadError}</div>
            ) : (
                <>
                    <section class="mt-6 overflow-hidden rounded-[1.75rem] p-0">
                        <div class="border-b border-stone-200/80 px-6 py-5">
                            <p class="eyebrow">Directory</p>
                            <h2 class="mt-2 text-3xl text-stone-950">Users</h2>
                        </div>
                        {users.length === 0 ? (
                            <div class="m-6 status-banner info">
                                No users yet.
                            </div>
                        ) : (
                            <div class="overflow-x-auto">
                                <table class="admin-table min-w-full bg-transparent">
                                    <thead>
                                        <tr>
                                            <th>User</th>
                                            <th>Status</th>
                                            <th>Roles</th>
                                            <th>Submissions</th>
                                            <th>Last login</th>
                                            <th>Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {users.map((user) => (
                                            <tr>
                                                <td>
                                                    <div class="font-medium text-stone-900">
                                                        {user.name ??
                                                            'Unnamed user'}
                                                    </div>
                                                    <div class="mt-1 text-sm text-stone-600">
                                                        {user.email}
                                                    </div>
                                                </td>
                                                <td>{user.status}</td>
                                                <td>
                                                    {user.roles.length
                                                        ? user.roles.join(', ')
                                                        : 'baseline only'}
                                                </td>
                                                <td>{user.submissionCount}</td>
                                                <td class="text-sm text-stone-600">
                                                    {user.lastLoginAt
                                                        ? new Date(
                                                              user.lastLoginAt,
                                                          ).toLocaleString()
                                                        : 'Never'}
                                                </td>
                                                <td class="text-sm text-stone-600">
                                                    {new Date(
                                                        user.createdAt,
                                                    ).toLocaleString()}
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        )}
                    </section>

                    <section class="mt-6 overflow-hidden rounded-[1.75rem] p-0">
                        <div class="border-b border-stone-200/80 px-6 py-5">
                            <p class="eyebrow">Inbox</p>
                            <h2 class="mt-2 text-3xl text-stone-950">
                                Waitlist submissions
                            </h2>
                        </div>
                        {entries.length === 0 ? (
                            <div class="m-6 status-banner info">
                                No submissions yet.
                            </div>
                        ) : (
                            <div class="overflow-x-auto">
                                <table class="admin-table min-w-full bg-transparent">
                                    <thead>
                                        <tr>
                                            <th>Created</th>
                                            <th>Email</th>
                                            <th>Name</th>
                                            <th>Source</th>
                                            <th>Status</th>
                                            <th>Note</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {entries.map((entry) => (
                                            <tr>
                                                <td class="text-sm text-stone-600">
                                                    {new Date(
                                                        entry.created_at,
                                                    ).toLocaleString()}
                                                </td>
                                                <td class="font-medium text-stone-900">
                                                    {entry.email}
                                                </td>
                                                <td>{entry.name ?? 'None'}</td>
                                                <td>{entry.source}</td>
                                                <td>{entry.status}</td>
                                                <td class="max-w-[28rem] whitespace-pre-wrap text-stone-700">
                                                    {entry.note ?? 'None'}
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        )}
                    </section>
                </>
            )
        }
    </div>
</Layout>
