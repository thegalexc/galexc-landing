---
import Layout from '../layouts/Layout.astro';
import { listWaitlistEntries, getWaitlistStats } from '../lib/waitlist';
import type { WaitlistEntryRecord } from '../lib/waitlist';

const adminUser = Astro.locals.adminUser;
let entries: WaitlistEntryRecord[] = [];
let stats = { total: 0, today: 0 };
let loadError: string | null = null;

try {
  entries = await listWaitlistEntries();
  stats = await getWaitlistStats();
} catch (error) {
  loadError = error instanceof Error ? error.message : 'Failed to load waitlist data.';
}
---

<Layout title="GalexC Admin" description="Private admin dashboard for GalexC waitlist review." noindex>
  <div class="editorial-shell px-4 py-8 md:px-6 md:py-10">
    <header class="panel rounded-[1.75rem] p-6 md:p-8">
      <p class="eyebrow">Private admin surface</p>
      <div class="mt-3 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h1 class="text-5xl text-stone-950 md:text-6xl">Waitlist inbox</h1>
          <p class="mt-3 text-lg leading-8 text-stone-700">
            Protected by Cloudflare Access. Signed in as <span class="font-medium text-stone-900">{adminUser?.email}</span>.
          </p>
        </div>
        <div class="grid gap-3 md:grid-cols-2">
          <div class="panel rounded-[1.25rem] bg-white/55 px-5 py-4">
            <div class="metric-value text-[2.4rem]">{stats.total}</div>
            <div class="metric-label">Total signups</div>
          </div>
          <div class="panel rounded-[1.25rem] bg-white/55 px-5 py-4">
            <div class="metric-value text-[2.4rem]">{stats.today}</div>
            <div class="metric-label">Today</div>
          </div>
        </div>
      </div>
    </header>

    <section class="mt-6 panel overflow-hidden rounded-[1.75rem] p-0">
      {loadError ? (
        <div class="status-banner error m-6">{loadError}</div>
      ) : entries.length === 0 ? (
        <div class="m-6 status-banner info">No signups yet.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="admin-table min-w-full bg-transparent">
            <thead>
              <tr>
                <th>Created</th>
                <th>Email</th>
                <th>Name</th>
                <th>Source</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {entries.map((entry) => (
                <tr>
                  <td class="text-sm text-stone-600">{new Date(entry.created_at).toLocaleString()}</td>
                  <td class="font-medium text-stone-900">{entry.email}</td>
                  <td>{entry.name ?? '—'}</td>
                  <td>{entry.source}</td>
                  <td>{entry.status}</td>
                  <td class="max-w-[28rem] whitespace-pre-wrap text-stone-700">{entry.note ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</Layout>
