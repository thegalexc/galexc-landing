---
import ContentsPageShell from '../components/ContentsPageShell.astro';
import Layout from '../layouts/Layout.astro';
import { navGroups, contentsVariants } from '../lib/site-content';

const variant = contentsVariants[2];
---

<Layout title="GalexC - Contents Register" description="GalexC contents register." noindex>
    <div class="editorial-shell px-4 py-8 md:px-6 md:py-12">
        <ContentsPageShell
            current={variant.slug}
            title={variant.title}
            intro={variant.intro}
        >
            <div class="contents-register">
                {
                    navGroups.map((group) => (
                        <section class="contents-register__group">
                            <div class="contents-register__header">
                                <p class="eyebrow">{group.title}</p>
                                <p class="contents-register__summary">{group.intro}</p>
                            </div>
                            <div class="contents-register__rows">
                                {
                                    group.items.map((item, index) => (
                                        <a class="contents-register__row" href={`/${item.slug}`}>
                                            <span class="contents-register__code">
                                                {group.title.slice(0, 1).toUpperCase()}.{String(index + 1).padStart(2, '0')}
                                            </span>
                                            <span class="contents-register__label">{item.label}</span>
                                            <span class="contents-register__blurb">{item.blurb}</span>
                                        </a>
                                    ))
                                }
                            </div>
                        </section>
                    ))
                }
            </div>
        </ContentsPageShell>
    </div>
</Layout>
